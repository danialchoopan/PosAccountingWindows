<UserControl x:Class="PosAccountingApp.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosAccountingApp.Converters">

    <UserControl.Resources>
        <conv:DecimalToPersianStringConverter x:Key="DecToPersian"/>
    </UserControl.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top: Alert Tiles -->
        <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,14">
            <Border Background="#FF0078D4" CornerRadius="10" Padding="16,14" Margin="6">
                <StackPanel>
                    <TextBlock Text="کل کالاها" FontSize="12" Foreground="#CCFFFFFF"/>
                    <TextBlock Text="{Binding TotalCount, StringFormat=N0}" FontSize="26" FontWeight="Bold"
                               Foreground="White" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="#FF2E7D32" CornerRadius="10" Padding="16,14" Margin="6">
                <StackPanel>
                    <TextBlock Text="ارزش موجودی" FontSize="12" Foreground="#CCFFFFFF"/>
                    <TextBlock Text="{Binding TotalValue, StringFormat=N0}" FontSize="20" FontWeight="Bold"
                               Foreground="White" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="#FFFF8C00" CornerRadius="10" Padding="16,14" Margin="6">
                <StackPanel>
                    <TextBlock Text="موجودی کم" FontSize="12" Foreground="#CCFFFFFF"/>
                    <TextBlock Text="{Binding LowStockCount}" FontSize="26" FontWeight="Bold"
                               Foreground="White" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="#FFD32F2F" CornerRadius="10" Padding="16,14" Margin="6">
                <StackPanel>
                    <TextBlock Text="موجودی صفر" FontSize="12" Foreground="#CCFFFFFF"/>
                    <TextBlock Text="{Binding EmptyStockCount}" FontSize="26" FontWeight="Bold"
                               Foreground="White" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Bottom: Tabs -->
        <TabControl Grid.Row="1">
            <TabItem Header="  همه کالاها">
                <DataGrid ItemsSource="{Binding AllProducts}" Margin="8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="عنوان" Binding="{Binding Title}" Width="*"/>
                        <DataGridTextColumn Header="موجودی" Binding="{Binding Stock}" Width="80"/>
                        <DataGridTextColumn Header="حداقل" Binding="{Binding MinStock}" Width="80"/>
                        <DataGridTextColumn Header="قیمت فروش" Binding="{Binding SalePrice}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="  موجودی کم">
                <DataGrid ItemsSource="{Binding LowStockProducts}" Margin="8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="عنوان" Binding="{Binding Title}" Width="*"/>
                        <DataGridTextColumn Header="موجودی" Binding="{Binding Stock}" Width="80"/>
                        <DataGridTextColumn Header="حداقل" Binding="{Binding MinStock}" Width="80"/>
                        <DataGridTextColumn Header="کمبود" Width="80">
                            <DataGridTextColumn.Binding>
                                <Binding Path="Stock" StringFormat="{}{0}"/>
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="  موجودی صفر">
                <DataGrid ItemsSource="{Binding EmptyStockProducts}" Margin="8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="عنوان" Binding="{Binding Title}" Width="*"/>
                        <DataGridTextColumn Header="حداقل موجودی" Binding="{Binding MinStock}" Width="120"/>
                        <DataGridTextColumn Header="قیمت خرید" Binding="{Binding PurchasePrice}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
