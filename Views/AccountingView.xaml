<UserControl x:Class="PosAccountingApp.Views.AccountingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosAccountingApp.Converters"
             xmlns:ctrl="clr-namespace:PosAccountingApp.Controls">

    <DockPanel Margin="14">
        <Border DockPanel.Dock="Top" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,0" VerticalContentAlignment="Center"/>
                <Button Grid.Column="1" Content="سند جدید"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ToggleAddPanelCommand}"/>
            </Grid>
        </Border>

        <!-- Add Panel -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}"
                Visibility="{Binding IsAddPanelOpen, Converter={StaticResource BoolToVis}}"
                Margin="0,0,0,10" Padding="18">
            <StackPanel>
                <TextBlock Text="ثبت سند حسابداری جدید" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"
                           Foreground="{DynamicResource AccentBrush}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="4">
                        <TextBlock Text="حساب" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <ComboBox ItemsSource="{Binding AccountList}" SelectedItem="{Binding EditAccount}"
                                  DisplayMemberPath="Name" Padding="8,5"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="4">
                        <TextBlock Text="بدهکار" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditDebit, UpdateSourceTrigger=PropertyChanged}" FlowDirection="LeftToRight"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="4">
                        <TextBlock Text="بستانکار" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditCredit, UpdateSourceTrigger=PropertyChanged}" FlowDirection="LeftToRight"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="4">
                        <TextBlock Text="توضیحات" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <!-- Totals -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="جمع بدهکار: " FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalDebit, StringFormat=N0}" FontSize="12" Foreground="{DynamicResource ErrorBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="جمع بستانکار: " FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalCredit, StringFormat=N0}" FontSize="12" Foreground="{DynamicResource SuccessBrush}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" FontSize="12" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="تراز نیست"/>
                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBalanced}" Value="True">
                                        <Setter Property="Text" Value="تراز است"/>
                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
                    <Button Content="افزودن ردیف" Style="{StaticResource SuccessButton}" Margin="0,0,6,0"
                            Command="{Binding AddLineCommand}"/>
                    <Button Content="ذخیره سند" Style="{StaticResource PrimaryButton}" Margin="0,0,6,0"
                            Command="{Binding SaveEntryCommand}"/>
                    <Button Content="انصراف" Style="{StaticResource DangerButton}"
                            Command="{Binding CancelEditCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Entries or Empty -->
        <Grid>
            <DataGrid ItemsSource="{Binding Entries}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="شماره سند" Binding="{Binding EntryNumber}" Width="140"/>
                    <DataGridTextColumn Header="تاریخ" Binding="{Binding EntryDate, StringFormat=yyyy/MM/dd}" Width="100"/>
                    <DataGridTextColumn Header="توضیحات" Binding="{Binding Description}" Width="*"/>
                    <DataGridTextColumn Header="بدهکار" Binding="{Binding TotalDebit}" Width="120"/>
                    <DataGridTextColumn Header="بستانکار" Binding="{Binding TotalCredit}" Width="120"/>
                    <DataGridTextColumn Header="وضعیت" Binding="{Binding Status}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border x:Name="EmptyState" Visibility="Collapsed" Background="Transparent" Padding="0,60,0,60">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                               Foreground="#FFCCCCCC" HorizontalAlignment="Center"/>
                    <TextBlock Text="هنوز سند حسابداری ثبت نشده."
                               FontSize="16" Foreground="#FFAAAAAA"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
