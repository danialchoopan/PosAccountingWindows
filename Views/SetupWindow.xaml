<Window x:Class="PosAccountingApp.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تنظیم اولیه سیستم"
        Width="1000" Height="700"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        FlowDirection="RightToLeft"
        Background="#FFF0F4F8"
        Icon="{StaticResource AppIcon}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="480"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Form Card -->
        <Border Grid.Column="1" Background="White" CornerRadius="16"
                BorderBrush="#FFE0E0E0" BorderThickness="1"
                Margin="0,20,0,20" Padding="32,24"
                VerticalAlignment="Center" MaxHeight="700">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.1" ShadowDepth="4"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Header -->
                    <Border Background="#FF0078D4" CornerRadius="12" Padding="20,18" Margin="0,0,0,24">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="تنظیم اولیه سیستم" FontSize="20" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,3"/>
                            <TextBlock Text="اطلاعات فروشگاه خود را وارد کنید" FontSize="12"
                                       Foreground="#CCFFFFFF" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Shop Name -->
                    <TextBlock Text="نام فروشگاه" FontSize="13" FontWeight="SemiBold"
                               Foreground="#FF333333" Margin="0,0,0,5"/>
                    <Border BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="6"
                            Background="White" Margin="0,0,0,14">
                        <TextBox x:Name="ShopNameBox" FontSize="14" Padding="12,10"
                                 Background="Transparent" BorderThickness="0"/>
                    </Border>

                    <!-- Business Type -->
                    <TextBlock Text="نوع کسب‌وکار" FontSize="13" FontWeight="SemiBold"
                               Foreground="#FF333333" Margin="0,0,0,5"/>
                    <Border BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="6"
                            Background="White" Margin="0,0,0,14">
                        <ComboBox x:Name="BusinessTypeCombo" FontSize="14" Padding="12,9"
                                  Background="Transparent" BorderThickness="0">
                            <ComboBoxItem Content="سوپرمارکت و خرده‌فروشی" Tag="Supermarket"/>
                            <ComboBoxItem Content="پوشاک و کیف و کفش" Tag="Boutique"/>
                            <ComboBoxItem Content="بنگاه املاک" Tag="RealEstate"/>
                            <ComboBoxItem Content="نمایشگاه خودرو" Tag="CarDealership"/>
                            <ComboBoxItem Content="فروشگاه مصالح ساختمانی" Tag="ConstructionMaterials"/>
                        </ComboBox>
                    </Border>

                    <!-- Phone -->
                    <TextBlock Text="تلفن فروشگاه" FontSize="13" FontWeight="SemiBold"
                               Foreground="#FF333333" Margin="0,0,0,5"/>
                    <Border BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="6"
                            Background="White" Margin="0,0,0,14">
                        <TextBox x:Name="PhoneBox" FontSize="14" Padding="12,10"
                                 Background="Transparent" BorderThickness="0"
                                 FlowDirection="LeftToRight"/>
                    </Border>

                    <!-- Address -->
                    <TextBlock Text="آدرس فروشگاه" FontSize="13" FontWeight="SemiBold"
                               Foreground="#FF333333" Margin="0,0,0,5"/>
                    <Border BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="6"
                            Background="White" Margin="0,0,0,14">
                        <TextBox x:Name="AddressBox" FontSize="14" Padding="12,10"
                                 Background="Transparent" BorderThickness="0"/>
                    </Border>

                    <!-- PIN -->
                    <TextBlock Text="کد عبور مدیر (۴ رقمی)" FontSize="13" FontWeight="SemiBold"
                               Foreground="#FF333333" Margin="0,0,0,5"/>
                    <Border BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="6"
                            Background="White" Margin="0,0,0,14">
                        <TextBox x:Name="PinBox" FontSize="22" Padding="12,10"
                                 MaxLength="4" FlowDirection="LeftToRight" FontWeight="Bold"
                                 HorizontalContentAlignment="Center"
                                 Background="Transparent" BorderThickness="0"/>
                    </Border>

                    <!-- VAT -->
                    <TextBlock Text="درصد مالیات (VAT)" FontSize="13" FontWeight="SemiBold"
                               Foreground="#FF333333" Margin="0,0,0,5"/>
                    <Border BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="6"
                            Background="White" Margin="0,0,0,14" Width="120" HorizontalAlignment="Left">
                        <TextBox x:Name="VatBox" FontSize="14" Padding="12,10"
                                 Text="10" FlowDirection="LeftToRight"
                                 HorizontalContentAlignment="Center"
                                 Background="Transparent" BorderThickness="0"/>
                    </Border>

                    <!-- Error -->
                    <TextBlock x:Name="ErrorText" Text="" Foreground="#FFD13438"
                               FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap"/>

                    <!-- Start Button -->
                    <Button x:Name="StartButton" Content="&#xE768;  شروع به کار"
                            Width="260" Height="50" FontSize="16" FontWeight="Bold"
                            Cursor="Hand" Margin="0,4,0,0"
                            HorizontalAlignment="Center"
                            Style="{StaticResource PrimaryButton}"
                            Click="StartButton_Click"/>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
