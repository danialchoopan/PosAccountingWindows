<Window x:Class="PosAccountingApp.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تنظیم اولیه سیستم"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        FlowDirection="RightToLeft"
        Background="#FFF0F4F8"
        Icon="{StaticResource AppIcon}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.25*"/>
            <ColumnDefinition Width="0.50*"/>
            <ColumnDefinition Width="0.25*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="1" Background="White" CornerRadius="16"
                BorderBrush="#FFE0E0E0" BorderThickness="1"
                VerticalAlignment="Center" HorizontalAlignment="Stretch"
                MaxWidth="550" Margin="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.1" ShadowDepth="4"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="850">
                <StackPanel Margin="8">
                    <!-- Header -->
                    <Border Background="#FF0078D4" CornerRadius="12" Padding="20,16" Margin="0,0,0,22">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="30"
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="تنظیم اولیه سیستم" FontSize="19" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,2"/>
                            <TextBlock Text="اطلاعات فروشگاه خود را وارد کنید" FontSize="12"
                                       Foreground="#CCFFFFFF" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Shop Name -->
                    <TextBlock Text="نام فروشگاه" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <Border BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="6"
                            Background="White" Margin="0,0,0,16">
                        <TextBox x:Name="ShopNameBox" FontSize="14" Padding="10,7"
                                 Background="Transparent" BorderThickness="0"/>
                    </Border>

                    <!-- Business Type -->
                    <TextBlock Text="نوع کسب‌وکار" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <Border BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="6"
                            Background="White" Margin="0,0,0,16">
                        <ComboBox x:Name="BusinessTypeCombo" FontSize="14" Padding="10,7"
                                  Background="Transparent" BorderThickness="0">
                            <ComboBoxItem Content="سوپرمارکت و خرده‌فروشی" Tag="Supermarket"/>
                            <ComboBoxItem Content="پوشاک و کیف و کفش" Tag="Boutique"/>
                            <ComboBoxItem Content="بنگاه املاک" Tag="RealEstate"/>
                            <ComboBoxItem Content="نمایشگاه خودرو" Tag="CarDealership"/>
                            <ComboBoxItem Content="فروشگاه مصالح ساختمانی" Tag="ConstructionMaterials"/>
                        </ComboBox>
                    </Border>

                    <!-- Phone -->
                    <TextBlock Text="تلفن فروشگاه" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <Border BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="6"
                            Background="White" Margin="0,0,0,16">
                        <TextBox x:Name="PhoneBox" FontSize="14" Padding="10,7"
                                 Background="Transparent" BorderThickness="0"
                                 FlowDirection="LeftToRight"/>
                    </Border>

                    <!-- Address -->
                    <TextBlock Text="آدرس فروشگاه" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <Border BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="6"
                            Background="White" Margin="0,0,0,16">
                        <TextBox x:Name="AddressBox" FontSize="14" Padding="10,7"
                                 Background="Transparent" BorderThickness="0"/>
                    </Border>

                    <!-- PIN -->
                    <TextBlock Text="کد عبور مدیر (۴ رقمی)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <Border BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="6"
                            Background="White" Margin="0,0,0,16">
                        <TextBox x:Name="PinBox" FontSize="22" Padding="10,7"
                                 MaxLength="4" FlowDirection="LeftToRight" FontWeight="Bold"
                                 HorizontalContentAlignment="Center"
                                 Background="Transparent" BorderThickness="0"/>
                    </Border>

                    <!-- VAT -->
                    <TextBlock Text="درصد مالیات (VAT)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <Border BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="6"
                            Background="White" Margin="0,0,0,16" Width="120" HorizontalAlignment="Left">
                        <TextBox x:Name="VatBox" FontSize="14" Padding="10,7" Text="10"
                                 FlowDirection="LeftToRight" HorizontalContentAlignment="Center"
                                 Background="Transparent" BorderThickness="0"/>
                    </Border>

                    <!-- Error -->
                    <TextBlock x:Name="ErrorText" Text="" Foreground="#FFD13438"
                               FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap"/>

                    <!-- Button -->
                    <Button x:Name="StartButton" Content="&#xE768;  شروع به کار"
                            FontFamily="Segoe MDL2 Assets" FontSize="16" FontWeight="Bold"
                            Width="260" Height="48" Cursor="Hand" Margin="0,4,0,16"
                            HorizontalAlignment="Center" Background="#FF0078D4" Foreground="White"
                            BorderThickness="0" Click="StartButton_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
