<Window x:Class="PosAccountingApp.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تنظیم اولیه سیستم"
        Width="540" Height="700"
        MinHeight="650"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="تنظیم اولیه سیستم" FontSize="24" FontWeight="Bold"
                       Foreground="#FF0078D4" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="1" Text="لطفاً اطلاعات فروشگاه خود را وارد کنید" FontSize="13"
                       Foreground="#FF666666" Margin="0,0,0,22"/>

            <StackPanel Grid.Row="2" Margin="0,0,0,16">
                <TextBlock Text="نام فروشگاه" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="ShopNameBox" FontSize="14" Padding="10,8" Height="38"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,0,0,16">
                <TextBlock Text="نوع کسب‌وکار" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="BusinessTypeCombo" FontSize="14" Padding="10,6" Height="38">
                    <ComboBoxItem Content="سوپرمارکت و خرده‌فروشی" Tag="Supermarket"/>
                    <ComboBoxItem Content="پوشاک و کیف و کفش" Tag="Boutique"/>
                    <ComboBoxItem Content="بنگاه املاک" Tag="RealEstate"/>
                    <ComboBoxItem Content="نمایشگاه خودرو" Tag="CarDealership"/>
                    <ComboBoxItem Content="فروشگاه مصالح ساختمانی" Tag="ConstructionMaterials"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Row="4" Margin="0,0,0,16">
                <TextBlock Text="تلفن فروشگاه" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="PhoneBox" FontSize="14" Padding="10,8" Height="38"
                         FlowDirection="LeftToRight"/>
            </StackPanel>

            <StackPanel Grid.Row="5" Margin="0,0,0,16">
                <TextBlock Text="آدرس فروشگاه" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="AddressBox" FontSize="14" Padding="10,8" Height="38"/>
            </StackPanel>

            <StackPanel Grid.Row="6" Margin="0,0,0,16">
                <TextBlock Text="کد عبور مدیر (۴ رقمی)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="PinBox" FontSize="20" Padding="10,8" Height="44"
                         MaxLength="4" FlowDirection="LeftToRight" FontWeight="Bold"
                         HorizontalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="7" Margin="0,0,0,8">
                <TextBlock Text="درصد مالیات (VAT)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="VatBox" FontSize="14" Padding="10,8" Height="38"
                         Text="10" FlowDirection="LeftToRight" HorizontalContentAlignment="Center"
                         Width="120" HorizontalAlignment="Left"/>
            </StackPanel>

            <TextBlock Grid.Row="8" x:Name="ErrorText" Text="" Foreground="#FFD13438"
                       FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>

            <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,20,0,20">
                <Button Content="شروع به کار" x:Name="StartButton" Width="200" Height="48"
                        FontSize="16" FontWeight="SemiBold"
                        Style="{StaticResource PrimaryButton}"
                        Click="StartButton_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
