<UserControl x:Class="PosAccountingApp.Views.SellsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosAccountingApp.Converters">

    <UserControl.Resources>
        <conv:DecimalToPersianStringConverter x:Key="DecToPersian"/>
        <conv:EnumToPersianConverter x:Key="EnumToPersian"/>
    </UserControl.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top: Stats Tiles -->
        <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,14">
            <Border Background="#FF0078D4" CornerRadius="10" Padding="16,14" Margin="6">
                <StackPanel>
                    <TextBlock Text="تعداد فاکتورها" FontSize="12" Foreground="#CCFFFFFF"/>
                    <TextBlock Text="{Binding TotalSalesCount}" FontSize="26" FontWeight="Bold"
                               Foreground="White" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="#FF2E7D32" CornerRadius="10" Padding="16,14" Margin="6">
                <StackPanel>
                    <TextBlock Text="کل درآمد" FontSize="12" Foreground="#CCFFFFFF"/>
                    <TextBlock Text="{Binding TotalRevenue, StringFormat=N0}" FontSize="18" FontWeight="Bold"
                               Foreground="White" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="#FF1565C0" CornerRadius="10" Padding="16,14" Margin="6">
                <StackPanel>
                    <TextBlock Text="سود خالص" FontSize="12" Foreground="#CCFFFFFF"/>
                    <TextBlock Text="{Binding TotalProfit, StringFormat=N0}" FontSize="18" FontWeight="Bold"
                               Foreground="White" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="#FFD32F2F" CornerRadius="10" Padding="16,14" Margin="6">
                <StackPanel>
                    <TextBlock Text="مرجوعی" FontSize="12" Foreground="#CCFFFFFF"/>
                    <TextBlock Text="{Binding ReturnedCount}" FontSize="26" FontWeight="Bold"
                               Foreground="White" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Bottom: Sales List + Items -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sales List -->
            <DockPanel Grid.Column="0" Margin="0,0,10,0">
                <Border DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,8,0" VerticalContentAlignment="Center"/>
                        <Button Grid.Column="1" Content="پاک کردن" Style="{StaticResource OutlineButton}"
                                Padding="10,6" Command="{Binding ClearSearchCommand}"/>
                    </Grid>
                </Border>

                <DataGrid ItemsSource="{Binding Sales}" MouseDoubleClick="SalesGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="شماره فاکتور" Binding="{Binding InvoiceNumber}" Width="140"/>
                        <DataGridTextColumn Header="تاریخ" Binding="{Binding CreatedAt, StringFormat=yyyy/MM/dd HH:mm}" Width="130"/>
                        <DataGridTextColumn Header="مبلغ" Binding="{Binding TotalAmount}" Width="120"/>
                        <DataGridTemplateColumn Header="وضعیت" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Status, Converter={StaticResource EnumToPersian}}" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="عملیات" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="مرجوع" Background="Transparent" BorderThickness="0"
                                            Foreground="{StaticResource ErrorBrush}" Cursor="Hand" FontSize="11"
                                            Command="{Binding DataContext.ReturnSaleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>

            <!-- Selected Sale Items -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="14">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="آیتم‌های فاکتور" FontSize="14" FontWeight="Bold"
                               Foreground="#FF0078D4" Margin="0,0,0,10"/>
                    <DataGrid ItemsSource="{Binding SelectedSaleItems}" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="کالا" Binding="{Binding ProductTitle}" Width="*"/>
                            <DataGridTextColumn Header="تعداد" Binding="{Binding Quantity}" Width="60"/>
                            <DataGridTextColumn Header="قیمت" Binding="{Binding UnitPrice}" Width="80"/>
                            <DataGridTextColumn Header="جمع" Binding="{Binding Subtotal}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
