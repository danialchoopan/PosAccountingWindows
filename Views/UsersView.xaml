<UserControl x:Class="PosAccountingApp.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosAccountingApp.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:EnumToPersianConverter x:Key="EnumToPersian"/>
    </UserControl.Resources>

    <DockPanel Margin="14">
        <Border DockPanel.Dock="Top" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="  کاربر جدید"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ToggleAddPanelCommand}"/>
            </StackPanel>
        </Border>

        <!-- Add Panel -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}"
                Visibility="{Binding IsAddPanelOpen, Converter={StaticResource BoolToVis}}"
                Margin="0,0,0,10" Padding="16">
            <StackPanel>
                <TextBlock Text="افزودن کاربر جدید" FontSize="15" FontWeight="Bold" Margin="0,0,0,10"
                           Foreground="#FF0078D4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="4">
                        <TextBlock Text="نام کاربر" FontSize="11" Foreground="#FF888888" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="4">
                        <TextBlock Text="کد عبور (حداقل ۴ رقم)" FontSize="11" Foreground="#FF888888" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditPin, UpdateSourceTrigger=PropertyChanged}"
                                 FlowDirection="LeftToRight" MaxLength="10"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="4">
                        <TextBlock Text="نقش" FontSize="11" Foreground="#FF888888" Margin="0,0,0,3"/>
                        <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding EditRole}"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
                    <Button Content="ذخیره" Style="{StaticResource PrimaryButton}" Margin="0,0,6,0"
                            Command="{Binding SaveUserCommand}"/>
                    <Button Content="انصراف" Style="{StaticResource DangerButton}"
                            Command="{Binding CancelEditCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Data Grid or Empty -->
        <Grid>
            <DataGrid ItemsSource="{Binding Users}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="نام" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="کد عبور" Binding="{Binding PinCodeHash}" Width="180" IsReadOnly="True"/>
                    <DataGridTextColumn Header="نقش" Binding="{Binding Role}" Width="120"/>
                    <DataGridTemplateColumn Header="حذف" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="حذف" Background="Transparent" BorderThickness="0"
                                        Foreground="#FFD13438" Cursor="Hand" FontSize="12"
                                        Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
            <TextBlock Text="هنوز کاربری وجود ندارد."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="14" Foreground="#FFAAAAAA" Visibility="Collapsed">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Users.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </DockPanel>
</UserControl>
