<Window x:Class="PosAccountingApp.Views.BarcodeScannerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="اسکن بارکد و QR"
        Width="1000" Height="650"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        Background="{DynamicResource BgBrush}"
        Icon="{StaticResource AppIcon}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.38*"/>
            <ColumnDefinition Width="0.62*"/>
        </Grid.ColumnDefinitions>

        <!-- Controls Panel -->
        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="{DynamicResource AccentBrush}" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="&#xE722;  اسکن بارکد و QR" FontFamily="Segoe MDL2 Assets"
                                   FontSize="18" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="دوربین یا اسکنر USB" FontSize="11"
                                   Foreground="#CCFFFFFF" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <StackPanel DockPanel.Dock="Bottom" Margin="16,16">
                    <Button x:Name="StartCamBtn" Content="&#xE722;  شروع دوربین" FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"
                            Margin="0,0,0,8" Click="StartCamBtn_Click"/>
                    <Button x:Name="StopCamBtn" Content="&#xE71A;  توقف" FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource DangerButton}" HorizontalAlignment="Stretch"
                            Margin="0,0,0,8" IsEnabled="False" Click="StopCamBtn_Click"/>
                    <Button Content="&#xE7E8;  بستن" FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource OutlineButton}" HorizontalAlignment="Stretch"
                            Click="Close_Click"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="16,16,16,0">
                    <TextBlock Text="&#xE70F;  ورود دستی کد" FontFamily="Segoe MDL2 Assets"
                               FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Border BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="2"
                            CornerRadius="6" Background="{DynamicResource InputBgBrush}" Margin="0,0,0,8">
                        <TextBox x:Name="ManualInput" FontSize="18" Padding="12,10"
                                 HorizontalContentAlignment="Center" FontWeight="Bold"
                                 FlowDirection="LeftToRight" Background="Transparent"
                                 BorderThickness="0" KeyDown="ManualInput_KeyDown"/>
                    </Border>
                    <Button Content="&#xE720;  افزودن کد" FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource SuccessButton}" HorizontalAlignment="Stretch"
                            Margin="0,0,0,10" Click="ManualAdd_Click"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="16,16,16,0">
                    <TextBlock Text="&#xE74E;  نتیجه اسکن" FontFamily="Segoe MDL2 Assets"
                               FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Background="{DynamicResource InputBgBrush}">
                        <TextBlock x:Name="ScanResultText" Text="---" FontSize="18" FontWeight="Bold"
                                   Padding="12,10" Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="16,16,16,0">
                    <TextBlock Text="&#xE81C;  تاریخچه اسکن" FontFamily="Segoe MDL2 Assets"
                               FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <ListBox x:Name="ScanHistory" MaxHeight="120"
                             BorderBrush="{DynamicResource BorderBrush}"
                             Background="{DynamicResource InputBgBrush}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Info Panel -->
        <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="#FF000000" Height="300" Margin="16,16,16,0"
                        CornerRadius="8">
                    <Grid>
                        <Image x:Name="CameraPreview" Stretch="Uniform"/>
                        <TextBlock x:Name="NoCameraText"
                                   Text="&#xE722;  دوربین متصل نیست" FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" Foreground="#FF888888"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" Margin="16,16,16,0"
                              MaxHeight="280">
                    <StackPanel>
                        <TextBlock Text="&#xE897;  راهنمای استفاده" FontFamily="Segoe MDL2 Assets"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,12"/>

                        <Border Background="{DynamicResource HoverBgBrush}" CornerRadius="8"
                                Padding="14" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="&#xE7F4;  روش ۱: دوربین وب‌کم" FontFamily="Segoe MDL2 Assets"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,6"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20"
                                           Foreground="{DynamicResource TextSecondaryBrush}">
                                    دوربین وب‌کم یا USB را وصل کنید و دکمه شروع دوربین را بزنید.
                                    دوربین را روی بارکد یا کد QR بگیرید تا به صورت خودکار شناسایی شود.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource HoverBgBrush}" CornerRadius="8"
                                Padding="14" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="&#xE7F3;  روش ۲: اسکنر USB" FontFamily="Segoe MDL2 Assets"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,6"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20"
                                           Foreground="{DynamicResource TextSecondaryBrush}">
                                    اسکنرهای USB بارکد مانند صفحه‌کلید عمل می‌کنند.
                                    کافیست بارکد را با اسکنر بخوانید و کد وارد می‌شود.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource HoverBgBrush}" CornerRadius="8"
                                Padding="14" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="&#xE8D4;  روش ۳: ورود دستی" FontFamily="Segoe MDL2 Assets"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,6"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20"
                                           Foreground="{DynamicResource TextSecondaryBrush}">
                                    کد بارکد را به صورت دستی در فیلد بالا تایپ کنید
                                    و دکمه افزودن را بزنید.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource HoverBgBrush}" CornerRadius="8"
                                Padding="14">
                            <StackPanel>
                                <TextBlock Text="&#xE7C3;  فرمت‌های پشتیبانی شده" FontFamily="Segoe MDL2 Assets"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,6"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20"
                                           Foreground="{DynamicResource TextSecondaryBrush}">
                                    EAN-13, EAN-8, Code 128, Code 39,
                                    QR Code, DataMatrix, UPC-A
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
