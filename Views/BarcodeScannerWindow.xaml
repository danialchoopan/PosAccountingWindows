<Window x:Class="PosAccountingApp.Views.BarcodeScannerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="اسکن بارکد"
        Width="900" Height="600"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        Background="#FFF0F4F8"
        Icon="{StaticResource AppIcon}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.35*"/>
            <ColumnDefinition Width="0.65*"/>
        </Grid.ColumnDefinitions>

        <!-- Controls -->
        <Border Grid.Column="0" Background="White" BorderBrush="#FFE0E0E0" BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="#FF0078D4" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="&#xE722;  اسکن بارکد و QR" FontFamily="Segoe MDL2 Assets"
                                   FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="اسکنر USB یا ورود دستی" FontSize="11"
                                   Foreground="#CCFFFFFF" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <StackPanel DockPanel.Dock="Top" Margin="16,16,16,0">
                    <TextBlock Text="کد بارکد یا QR را وارد کنید:" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Border BorderBrush="#FF0078D4" BorderThickness="2" CornerRadius="6" Background="White" Margin="0,0,0,8">
                        <TextBox x:Name="BarcodeInput" FontSize="20" Padding="12,10"
                                 HorizontalContentAlignment="Center" FontWeight="Bold"
                                 FlowDirection="LeftToRight"
                                 KeyDown="BarcodeInput_KeyDown"/>
                    </Border>
                    <TextBlock Text="اگر اسکنر USB دارید، بارکد را اسکن کنید (مثلاً وارد کردن کد به صورت خودکار)"
                               FontSize="11" Foreground="#FF888888" TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <Button x:Name="AddBtn" Content="افزودن به صندوق" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Stretch" Margin="0,0,0,8"
                            Click="AddBtn_Click"/>
                    <Button Content="بستن" Style="{StaticResource OutlineButton}"
                            HorizontalAlignment="Stretch"
                            Click="Close_Click"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="16,16,16,0">
                    <TextBlock Text="تاریخچه اسکن:" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <ListBox x:Name="ScanHistory" MaxHeight="200" BorderBrush="#FFE0E0E0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Info Panel -->
        <Border Grid.Column="1" Background="White" BorderBrush="#FFE0E0E0" BorderThickness="1,0,0,0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                <TextBlock Text="&#xE7F3;" FontFamily="Segoe MDL2 Assets" FontSize="64"
                           Foreground="#FF0078D4" HorizontalAlignment="Center"/>
                <TextBlock Text="نحوه استفاده" FontSize="20" FontWeight="Bold"
                           Foreground="#FF333333" HorizontalAlignment="Center" Margin="0,12,0,16"/>

                <Border Background="#FFF5F7FA" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="۱. اسکنر USB بارکد" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#FF0078D4" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="22">
                            اسکنرهای USB بارکد مانند صفحه‌کلید عمل می‌کنند. کافیست بارکد را با اسکنر بخوانید و کد به صورت خودکار در فیلد بالا وارد می‌شود. سپس روی افزودن به صندوق کلیک کنید.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Background="#FFF5F7FA" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="۲. ورود دستی" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#FF0078D4" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="22">
                            اگر اسکنر USB ندارید، کد بارکد را به صورت دستی در فیلد بالا تایپ کنید و روی افزودن به صندوق کلیک کنید. این روش برای تست و آزمایش مناسب است.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Background="#FFF5F7FA" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="۳. پشتیبانی از فرمت‌ها" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#FF0078D4" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="22">
                            سیستم از فرمت‌های زیر پشتیبانی می‌کند:
- EAN-13 / EAN-8 (بارکد محصولات)
- Code 128 / Code 39 (بارکد صنعتی)
- QR Code (کدهای دو بعدی)
- DataMatrix (بارکد صنعتی)
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Background="#FFF5F7FA" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="۴. سازگاری" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#FF0078D4" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="22">
                            اکثر اسکنرهای بارکد USB مانند Honeywell, Zebra, Datalogic و... به صورت پیش‌فرض با این برنامه سازگار هستند. فقط کافیست اسکنر را به کامپیوتر وصل کنید و بارکد را بخوانید.
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
