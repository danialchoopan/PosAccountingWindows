<Window x:Class="PosAccountingApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ورود به سیستم"
        Width="420" Height="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="ورود به سیستم" FontSize="22" FontWeight="Bold"
                   Foreground="#FF0078D4" HorizontalAlignment="Center" Margin="0,10,0,4"/>
        <TextBlock Grid.Row="1" Text="نام کاربر خود را انتخاب کرده و کد عبور را وارد کنید" FontSize="13"
                   Foreground="#FF888888" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="2" Margin="0,0,0,14">
            <TextBlock Text="کاربر" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ComboBox x:Name="UserCombo" FontSize="14" Padding="8,6" Height="38"
                      DisplayMemberPath="Name" SelectionChanged="UserCombo_SelectionChanged"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,14">
            <TextBlock Text="کد عبور" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PinBox" FontSize="22" Padding="8,6" Height="42"
                         MaxLength="10" HorizontalContentAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="4" Background="#FFF0F0F0" CornerRadius="4"
                Padding="10,6" Margin="0,0,0,14">
            <Grid>
                <TextBlock Text="نقش:" HorizontalAlignment="Left" Foreground="#FF888888" FontSize="12"/>
                <TextBlock x:Name="RoleLabel" Text="-" HorizontalAlignment="Right"
                           FontSize="12" FontWeight="SemiBold" Foreground="#FF333333"/>
            </Grid>
        </Border>

        <TextBlock Grid.Row="5" x:Name="ErrorText" Text="" Foreground="#FFD13438"
                   FontSize="12" Margin="0,0,0,6" TextAlignment="Center"/>

        <TextBlock Grid.Row="6" x:Name="NoUsersText"
                   Text="هنوز کاربری وجود ندارد. از صفحه تنظیمات کاربر بسازید."
                   FontSize="13" Foreground="#FF888888" HorizontalAlignment="Center"
                   VerticalAlignment="Center" Visibility="Collapsed"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="ورود" x:Name="LoginButton" Width="160" Height="42"
                    FontSize="15" FontWeight="SemiBold"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,0,0,8"
                    Click="LoginButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
