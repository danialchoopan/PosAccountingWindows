<Window x:Class="PosAccountingApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ورود به سیستم"
        Width="1000" Height="700"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        FlowDirection="RightToLeft"
        Background="#FFF0F4F8"
        Icon="{StaticResource AppIcon}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="1" Background="White" CornerRadius="16"
                BorderBrush="#FFE0E0E0" BorderThickness="1"
                Margin="0,20,0,20" Padding="36,28"
                VerticalAlignment="Center" MaxHeight="600">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.1" ShadowDepth="4"/>
            </Border.Effect>

            <StackPanel>
                <!-- Header -->
                <Border Background="#FF0078D4" CornerRadius="12" Padding="20,18" Margin="0,0,0,24">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                                   Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="ورود به سیستم" FontSize="20" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,3"/>
                        <TextBlock Text="کاربر خود را انتخاب کرده و کد عبور را وارد کنید" FontSize="12"
                                   Foreground="#CCFFFFFF" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- User -->
                <TextBlock Text="کاربر" FontSize="13" FontWeight="SemiBold"
                           Foreground="#FF333333" Margin="0,0,0,5"/>
                <Border BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="6"
                        Background="White" Margin="0,0,0,14">
                    <ComboBox x:Name="UserCombo" FontSize="14" Padding="12,9"
                              DisplayMemberPath="Name" Background="Transparent"
                              BorderThickness="0" SelectionChanged="UserCombo_SelectionChanged"/>
                </Border>

                <!-- PIN -->
                <TextBlock Text="کد عبور" FontSize="13" FontWeight="SemiBold"
                           Foreground="#FF333333" Margin="0,0,0,5"/>
                <Border BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="6"
                        Background="White" Margin="0,0,0,14">
                    <PasswordBox x:Name="PinBox" FontSize="20" Padding="12,10"
                                 MaxLength="10" HorizontalContentAlignment="Center"/>
                </Border>

                <!-- Role Display -->
                <Border Background="#FFF5F7FA" BorderBrush="#FFE8E8E8"
                        BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,14">
                    <Grid>
                        <TextBlock Text="نقش:" HorizontalAlignment="Left"
                                   Foreground="#FF888888" FontSize="12"/>
                        <TextBlock x:Name="RoleLabel" Text="-" HorizontalAlignment="Right"
                                   FontSize="12" FontWeight="SemiBold" Foreground="#FF333333"/>
                    </Grid>
                </Border>

                <!-- Error -->
                <TextBlock x:Name="ErrorText" Text="" Foreground="#FFD13438"
                           FontSize="12" Margin="0,0,0,8" TextAlignment="Center"/>

                <!-- No Users -->
                <TextBlock x:Name="NoUsersText"
                           Text="هنوز کاربری وجود ندارد."
                           FontSize="12" Foreground="#FF888888" HorizontalAlignment="Center"
                           Visibility="Collapsed"/>

                <!-- Login Button -->
                <Button x:Name="LoginButton" Content="&#xE768;  ورود"
                        Width="200" Height="48" FontSize="16" FontWeight="Bold"
                        Cursor="Hand" Margin="0,8,0,0"
                        HorizontalAlignment="Center"
                        Style="{StaticResource PrimaryButton}"
                        Click="LoginButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
