<UserControl x:Class="PosAccountingApp.Views.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosAccountingApp.Converters"
             xmlns:vm="clr-namespace:PosAccountingApp.ViewModels"
             xmlns:m="clr-namespace:PosAccountingApp.Models"
             x:Name="Root">

    <UserControl.Resources>
        <conv:DecimalToPersianStringConverter x:Key="DecToPersian"/>
        <conv:EnumToPersianConverter x:Key="EnumToPersian"/>
    </UserControl.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Cart -->
        <DockPanel Grid.Column="0" Margin="0,0,10,0">
            <!-- Search Box -->
            <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchBox" FontSize="16" Padding="12,10"
                             VerticalContentAlignment="Center"
                             TextChanged="SearchBox_TextChanged"
                             KeyDown="SearchBox_KeyDown"/>
                    <Button Grid.Column="1" Content="افزودن"
                            Style="{StaticResource PrimaryButton}" Padding="14,8" Margin="8,0,0,0"
                            Click="AddButton_Click"/>
                </Grid>
            </Border>

            <!-- Search Results -->
            <Border DockPanel.Dock="Top" Background="White" BorderBrush="#FFE0E0E0"
                    BorderThickness="1" CornerRadius="6" Margin="0,4,0,0"
                    x:Name="SearchDropdown" Visibility="Collapsed">
                <ListBox x:Name="SearchResultsList" BorderThickness="0"
                         MaxHeight="200"
                         DisplayMemberPath="Title"
                         SelectionChanged="SearchResultsList_SelectionChanged"
                         KeyDown="SearchResultsList_KeyDown"/>
            </Border>

            <!-- Cart Table -->
            <DataGrid x:Name="CartGrid" Margin="0,8,0,0" AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="کالا" Binding="{Binding ProductTitle}" Width="*"/>
                    <DataGridTemplateColumn Header="تعداد" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="+" Background="#FF2E7D32" Foreground="White"
                                            BorderThickness="0" Padding="8,2" Cursor="Hand" FontSize="14"
                                            Tag="{Binding}" Click="IncBtn_Click"/>
                                    <TextBlock Text="{Binding Quantity, StringFormat=N0}" VerticalAlignment="Center"
                                               FontSize="14" FontWeight="Bold" Margin="8,0"/>
                                    <Button Content="-" Background="#FFD32F2F" Foreground="White"
                                            BorderThickness="0" Padding="8,2" Cursor="Hand" FontSize="14"
                                            Tag="{Binding}" Click="DecBtn_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="قیمت" Binding="{Binding UnitPrice, StringFormat=N0}" Width="100"/>
                    <DataGridTextColumn Header="جمع" Binding="{Binding Subtotal, StringFormat=N0}" Width="100"/>
                    <DataGridTemplateColumn Header="حذف" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="X" Background="Transparent" BorderThickness="0"
                                        Foreground="#FFD32F2F" Cursor="Hand" FontSize="14" FontWeight="Bold"
                                        Tag="{Binding}" Click="DelBtn_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Right: Summary -->
        <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="16">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="نام مشتری" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="CustomerNameBox" DockPanel.Dock="Top" Margin="0,0,0,12"/>

                <Border DockPanel.Dock="Top" Background="#FFF5F7FA" BorderBrush="#FFE0E0E0"
                        BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="جمع کل" HorizontalAlignment="Left" FontWeight="SemiBold"/>
                            <TextBlock x:Name="SubtotalText" Text="0" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="مالیات (۱۰٪)" HorizontalAlignment="Left"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="TaxText" Text="0" HorizontalAlignment="Right"/>
                        </Grid>
                        <Separator Background="#FFE0E0E0" Margin="0,6"/>
                        <Grid Margin="0,6,0,0">
                            <TextBlock Text="مبلغ قابل پرداخت" HorizontalAlignment="Left"
                                       FontSize="15" FontWeight="Bold"/>
                            <TextBlock x:Name="TotalText" Text="0" HorizontalAlignment="Right"
                                       FontSize="20" FontWeight="Bold" Foreground="#FF107C10"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock DockPanel.Dock="Top" Text="روش پرداخت" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <ComboBox x:Name="PaymentCombo" DockPanel.Dock="Top" Padding="10,7" Margin="0,0,0,10">
                    <ComboBoxItem Content="نقدی"/>
                    <ComboBoxItem Content="کارتخوان"/>
                    <ComboBoxItem Content="نسیه"/>
                    <ComboBoxItem Content="اقساطی"/>
                </ComboBox>

                <CheckBox x:Name="FullyPaidChk" Content="پول کامل پرداخت شده"
                          IsChecked="True" FontSize="13" DockPanel.Dock="Top"
                          Checked="FullyPaidChk_Checked" Unchecked="FullyPaidChk_Unchecked"
                          Margin="0,0,0,8"/>

                <TextBlock DockPanel.Dock="Top" Text="مبلغ پرداختی" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="PaidAmountBox" DockPanel.Dock="Top" FontSize="15"/>

                <Border DockPanel.Dock="Top" Background="#FFDFF6DD" BorderBrush="#FF107C10"
                        BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,10,0,0">
                    <Grid>
                        <TextBlock Text="باقیمانده" HorizontalAlignment="Left" FontWeight="SemiBold"
                                   Foreground="#FF107C10"/>
                        <TextBlock x:Name="ChangeText" Text="0" HorizontalAlignment="Right"
                                   FontSize="17" FontWeight="Bold" Foreground="#FF107C10"/>
                    </Grid>
                </Border>

                <Button x:Name="FinalizeBtn" Content="تکمیل فروش" DockPanel.Dock="Bottom"
                        Style="{StaticResource SuccessButton}" FontSize="15" Padding="10,12"
                        Margin="0,10,0,0" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center" Click="FinalizeBtn_Click"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
