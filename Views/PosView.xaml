<UserControl x:Class="PosAccountingApp.Views.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosAccountingApp.Converters"
             xmlns:vm="clr-namespace:PosAccountingApp.ViewModels"
             xmlns:m="clr-namespace:PosAccountingApp.Models">

    <UserControl.Resources>
        <conv:DecimalToPersianStringConverter x:Key="DecToPersian"/>
        <conv:EnumToPersianConverter x:Key="EnumToPersian"/>
    </UserControl.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Cart -->
        <DockPanel Grid.Column="0" Margin="0,0,10,0">
            <!-- Barcode/Search -->
            <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <TextBox Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="15" Padding="10,8"
                                 KeyDown="BarcodeInput_KeyDown"
                                 VerticalContentAlignment="Center"/>

                        <!-- Search Results Popup -->
                        <Border Grid.Column="0" Background="White" BorderBrush="#FFCCCCCC"
                                BorderThickness="1" CornerRadius="6" Margin="0,2,0,0"
                                MaxHeight="300" VerticalAlignment="Top"
                                Visibility="{Binding IsSearchOpen, Converter={StaticResource BoolToVis}}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding SearchResults}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type m:Product}">
                                            <Border Padding="10,8" Cursor="Hand" Margin="2"
                                                    BorderBrush="#FFE8E8E8" BorderThickness="1" CornerRadius="4">
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick"
                                                                  Command="{Binding DataContext.AddProductToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  CommandParameter="{Binding}"/>
                                                </Border.InputBindings>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Barcode}"
                                                               FontSize="11" Foreground="#FF888888"
                                                               Margin="12,0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Stock}"
                                                               FontSize="11" Foreground="#FF107C10"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                    <Button Grid.Column="1" Content="افزودن" Style="{StaticResource PrimaryButton}"
                            Padding="12,8" Margin="8,0,0,0"
                            Command="{Binding AddByBarcodeCommand}"/>
                </Grid>
            </Border>

            <!-- Cart Grid or Empty -->
            <Grid Margin="0,10,0,0">
                <DataGrid ItemsSource="{Binding CartItems}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="کالا" Binding="{Binding ProductTitle}" Width="*"/>
                        <DataGridTextColumn Header="تعداد" Binding="{Binding Quantity}" Width="80"/>
                        <DataGridTextColumn Header="قیمت واحد" Binding="{Binding UnitPrice}" Width="120"/>
                        <DataGridTextColumn Header="جمع" Binding="{Binding Subtotal}" Width="120"/>
                        <DataGridTemplateColumn Header="حذف" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="X" Background="Transparent" BorderThickness="0"
                                            Foreground="#FFD13438" Cursor="Hand" FontSize="12" FontWeight="Bold"
                                            Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border x:Name="EmptyCart" Background="Transparent" Padding="0,60,0,60">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                                   Foreground="#FFCCCCCC" HorizontalAlignment="Center"/>
                        <TextBlock Text="سبد خرید خالی است" FontSize="16" Foreground="#FFAAAAAA"
                                   HorizontalAlignment="Center" Margin="0,12,0,0"/>
                        <TextBlock Text="نام یا بارکد کالا را تایپ کنید" FontSize="12"
                                   Foreground="#FFCCCCCC" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DockPanel>

        <!-- Summary -->
        <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="16">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <TextBlock Text="نام مشتری" FontSize="11" Foreground="#FF888888" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top">
                    <Border Background="#FFF5F7FA" BorderBrush="#FFE8E8E8" BorderThickness="1" CornerRadius="8" Padding="14">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="جمع کل" HorizontalAlignment="Left" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Subtotal, StringFormat=N0}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="مالیات (۱۰٪)" HorizontalAlignment="Left" Foreground="#FF888888"/>
                                <TextBlock Text="{Binding TaxAmount, StringFormat=N0}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Separator Background="#FFE8E8E8" Margin="0,6"/>
                            <Grid Margin="0,6,0,0">
                                <TextBlock Text="مبلغ قابل پرداخت" HorizontalAlignment="Left" FontSize="15" FontWeight="Bold"/>
                                <TextBlock Text="{Binding TotalAmount, StringFormat=N0}" HorizontalAlignment="Right"
                                           FontSize="20" FontWeight="Bold" Foreground="#FF107C10"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="0,12,0,0">
                    <TextBlock Text="روش پرداخت" FontSize="11" Foreground="#FF888888" Margin="0,0,0,3"/>
                    <ComboBox ItemsSource="{Binding PaymentMethods}"
                              SelectedItem="{Binding SelectedPaymentMethod}" Padding="10,6">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumToPersian}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="0,10,0,0">
                    <TextBlock Text="مبلغ پرداختی" FontSize="11" Foreground="#FF888888" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding CustomerPaid, UpdateSourceTrigger=PropertyChanged}" FontSize="15"/>
                </StackPanel>

                <Border DockPanel.Dock="Top" Background="#FFDFF6DD" BorderBrush="#FF107C10"
                        BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,10,0,0">
                    <Grid>
                        <TextBlock Text="باقیمانده" HorizontalAlignment="Left" FontWeight="SemiBold" Foreground="#FF107C10"/>
                        <TextBlock Text="{Binding ChangeAmount, StringFormat=N0}" HorizontalAlignment="Right"
                                   FontSize="17" FontWeight="Bold" Foreground="#FF107C10"/>
                    </Grid>
                </Border>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                    <Button Content="تکمیل فروش" Style="{StaticResource SuccessButton}"
                            FontSize="15" Padding="10,12" Margin="0,0,0,6"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Command="{Binding FinalizeSaleCommand}"/>
                    <Button Content="نگهداری فاکتور (F4)" Style="{StaticResource WarningButton}"
                            Margin="0,0,0,6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Command="{Binding SuspendInvoiceCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
