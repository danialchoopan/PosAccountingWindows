<UserControl x:Class="PosAccountingApp.Views.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosAccountingApp.Converters"
             xmlns:vm="clr-namespace:PosAccountingApp.ViewModels"
             xmlns:m="clr-namespace:PosAccountingApp.Models"
             x:Name="ThisControl">

    <UserControl.Resources>
        <conv:DecimalToPersianStringConverter x:Key="DecToPersian"/>
        <conv:EnumToPersianConverter x:Key="EnumToPersian"/>
    </UserControl.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Cart -->
        <DockPanel Grid.Column="0" Margin="0,0,10,0">
            <!-- Barcode/Search Input -->
            <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <TextBox x:Name="BarcodeBox" FontSize="16" Padding="12,10"
                                 TextChanged="BarcodeBox_TextChanged"
                                 KeyDown="BarcodeBox_KeyDown"
                                 VerticalContentAlignment="Center"/>
                        <Border Background="White" BorderBrush="#FFE0E0E0" BorderThickness="1"
                                CornerRadius="6" VerticalAlignment="Top"
                                Visibility="{Binding IsSearchOpen, Converter={StaticResource BoolToVis}}"
                                MaxHeight="220">
                            <ListBox x:Name="SearchList" BorderThickness="0"
                                     Background="White"
                                     KeyDown="SearchList_KeyDown"
                                     SelectionChanged="SearchList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type m:Product}">
                                        <Border Padding="10,8" Margin="2"
                                                BorderBrush="#FFE8E8E8" BorderThickness="1" CornerRadius="4"
                                                Background="White">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Barcode}" FontSize="11" Foreground="#FF888888" Margin="10,0" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Stock}" FontSize="11" Foreground="#FF107C10" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>
                    <Button Grid.Column="1" Content="افزودن"
                            Style="{StaticResource PrimaryButton}" Padding="14,8" Margin="8,0,0,0"
                            Click="AddBtn_Click"/>
                </Grid>
            </Border>

            <!-- Cart Table -->
            <Grid Margin="0,10,0,0">
                <DataGrid x:Name="CartGrid" ItemsSource="{Binding CartItems}" AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="کالا" Binding="{Binding ProductTitle}" Width="*"/>
                        <DataGridTemplateColumn Header="تعداد" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="+" Background="#FF2E7D32" Foreground="White"
                                                BorderThickness="0" Padding="8,2" Cursor="Hand" FontSize="14"
                                                Tag="{Binding}" Click="IncreaseBtn_Click"/>
                                        <TextBlock Text="{Binding Quantity, StringFormat=N0}" VerticalAlignment="Center"
                                                   HorizontalAlignment="Center" FontSize="14" FontWeight="Bold" Margin="8,0"/>
                                        <Button Content="-" Background="#FFD32F2F" Foreground="White"
                                                BorderThickness="0" Padding="8,2" Cursor="Hand" FontSize="14"
                                                Tag="{Binding}" Click="DecreaseBtn_Click"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="قیمت واحد" Binding="{Binding UnitPrice, StringFormat=N0}" Width="100"/>
                        <DataGridTextColumn Header="جمع" Binding="{Binding Subtotal, StringFormat=N0}" Width="100"/>
                        <DataGridTemplateColumn Header="حذف" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="X" Background="Transparent" BorderThickness="0"
                                            Foreground="#FFD32F2F" Cursor="Hand" FontSize="14" FontWeight="Bold"
                                            Tag="{Binding}" Click="DeleteBtn_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border x:Name="EmptyCart" Background="Transparent" Padding="0,60,0,60" Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="سبد خرید خالی است" FontSize="16"
                                   Foreground="#FFAAAAAA" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DockPanel>

        <!-- Right: Summary -->
        <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="18">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <TextBlock Text="نام مشتری" FontSize="12" Foreground="#FF888888" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top">
                    <Border Background="#FFF5F7FA" BorderBrush="#FFE0E0E0" BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="جمع کل" HorizontalAlignment="Left" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Subtotal, StringFormat=N0}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="مالیات (10%)" HorizontalAlignment="Left" Foreground="#FF888888"/>
                                <TextBlock Text="{Binding TaxAmount, StringFormat=N0}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Separator Background="#FFE0E0E0" Margin="0,6"/>
                            <Grid Margin="0,6,0,0">
                                <TextBlock Text="مبلغ قابل پرداخت" HorizontalAlignment="Left" FontSize="15" FontWeight="Bold"/>
                                <TextBlock Text="{Binding TotalAmount, StringFormat=N0}" HorizontalAlignment="Right"
                                           FontSize="20" FontWeight="Bold" Foreground="#FF107C10"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="0,12,0,0">
                    <TextBlock Text="روش پرداخت" FontSize="12" Foreground="#FF888888" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding PaymentMethods}" SelectedItem="{Binding SelectedPaymentMethod}" Padding="10,7">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumToPersian}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="0,10,0,0">
                    <CheckBox x:Name="FullyPaidCheck" Content="پول کامل پرداخت شده"
                              IsChecked="True" FontSize="13" Checked="FullyPaid_Checked"
                              Unchecked="FullyPaid_Unchecked"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                    <TextBlock Text="مبلغ پرداختی" FontSize="12" Foreground="#FF888888" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding CustomerPaid, UpdateSourceTrigger=PropertyChanged}" FontSize="15"/>
                </StackPanel>

                <Border DockPanel.Dock="Top" Background="#FFDFF6DD" BorderBrush="#FF107C10"
                        BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,10,0,0">
                    <Grid>
                        <TextBlock Text="باقیمانده" HorizontalAlignment="Left" FontWeight="SemiBold" Foreground="#FF107C10"/>
                        <TextBlock Text="{Binding ChangeAmount, StringFormat=N0}" HorizontalAlignment="Right"
                                   FontSize="17" FontWeight="Bold" Foreground="#FF107C10"/>
                    </Grid>
                </Border>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                    <Button Content="تکمیل فروش" Style="{StaticResource SuccessButton}"
                            FontSize="15" Padding="10,12" Margin="0,0,0,6"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Click="FinalizeBtn_Click"/>
                    <Button Content="نگهداری فاکتور" Style="{StaticResource WarningButton}"
                            Margin="0,0,0,6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Command="{Binding SuspendInvoiceCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
