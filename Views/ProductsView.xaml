<UserControl x:Class="PosAccountingApp.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosAccountingApp.Converters"
             xmlns:ctrl="clr-namespace:PosAccountingApp.Controls">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:EnumToPersianConverter x:Key="EnumToPersian"/>
    </UserControl.Resources>

    <DockPanel Margin="14">
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,0" VerticalContentAlignment="Center"/>
                <Button Grid.Column="1" Content="  کالای جدید"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ToggleAddPanelCommand}"/>
            </Grid>
        </Border>

        <!-- Add Panel -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}"
                Visibility="{Binding IsAddPanelOpen, Converter={StaticResource BoolToVis}}"
                Margin="0,0,0,10" Padding="18">
            <StackPanel>
                <TextBlock Text="اطلاعات کالا" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"
                           Foreground="{DynamicResource AccentBrush}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="4">
                        <TextBlock Text="عنوان کالا *" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="4">
                        <TextBlock Text="بارکد" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditBarcode, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="4">
                        <TextBlock Text="دسته‌بندی" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <ComboBox ItemsSource="{Binding Categories}" Text="{Binding EditCategory, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="4">
                        <TextBlock Text="واحد" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <ComboBox ItemsSource="{Binding UnitTypes}" SelectedItem="{Binding EditUnit}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumToPersian}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="4">
                        <TextBlock Text="قیمت خرید" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditPurchasePrice, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="4">
                        <TextBlock Text="قیمت فروش" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditSalePrice, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="4">
                        <TextBlock Text="موجودی" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditStock, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="4">
                        <TextBlock Text="حداقل موجودی" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditMinStock, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
                    <Button Content="ذخیره" Style="{StaticResource PrimaryButton}" Margin="0,0,6,0"
                            Command="{Binding SaveProductCommand}"/>
                    <Button Content="انصراف" Style="{StaticResource DangerButton}"
                            Command="{Binding CancelEditCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Paginated Grid -->
        <ctrl:PaginatedDataGrid x:Name="PagedGrid" Margin="0,0,0,0"/>
    </DockPanel>
</UserControl>
