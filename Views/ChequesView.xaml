<UserControl x:Class="PosAccountingApp.Views.ChequesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosAccountingApp.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:EnumToPersianConverter x:Key="EnumToPersian"/>
    </UserControl.Resources>

    <DockPanel Margin="14">
        <Border DockPanel.Dock="Top" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Tag="جستجوی چک..." Margin="0,0,8,0" VerticalContentAlignment="Center"/>
                <Button Grid.Column="1" Content="  چک جدید"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ToggleAddPanelCommand}"/>
            </Grid>
        </Border>

        <!-- Add Panel -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}"
                Visibility="{Binding IsAddPanelOpen, Converter={StaticResource BoolToVis}}"
                Margin="0,0,0,10" Padding="16">
            <StackPanel>
                <TextBlock Text="اطلاعات چک" FontSize="15" FontWeight="Bold" Margin="0,0,0,10"
                           Foreground="#FF0078D4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="4">
                        <TextBlock Text="شماره چک" FontSize="11" Foreground="#FF888888" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditChequeNumber, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="4">
                        <TextBlock Text="نام بانک" FontSize="11" Foreground="#FF888888" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditBankName, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="4">
                        <TextBlock Text="مبلغ" FontSize="11" Foreground="#FF888888" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditAmount, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="4">
                        <TextBlock Text="تاریخ سررسید" FontSize="11" Foreground="#FF888888" Margin="0,0,0,3"/>
                        <DatePicker SelectedDate="{Binding EditDueDate}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="4">
                        <TextBlock Text="صاحب چک" FontSize="11" Foreground="#FF888888" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditPayerName, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="4">
                        <TextBlock Text="نوع" FontSize="11" Foreground="#FF888888" Margin="0,0,0,3"/>
                        <ComboBox SelectedItem="{Binding EditType}"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
                    <Button Content="ذخیره" Style="{StaticResource PrimaryButton}" Margin="0,0,6,0"
                            Command="{Binding SaveChequeCommand}"/>
                    <Button Content="انصراف" Style="{StaticResource DangerButton}"
                            Command="{Binding CancelEditCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Data Grid or Empty State -->
        <Grid>
            <DataGrid ItemsSource="{Binding Cheques}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="شماره چک" Binding="{Binding ChequeNumber}" Width="120"/>
                    <DataGridTextColumn Header="بانک" Binding="{Binding BankName}" Width="100"/>
                    <DataGridTextColumn Header="مبلغ" Binding="{Binding Amount}" Width="120"/>
                    <DataGridTextColumn Header="سررسید" Binding="{Binding DueDate, StringFormat=yyyy/MM/dd}" Width="100"/>
                    <DataGridTextColumn Header="صاحب چک" Binding="{Binding PayerName}" Width="*"/>
                    <DataGridTextColumn Header="وضعیت" Binding="{Binding Status}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
            <TextBlock Text="هنوز چکی ثبت نشده است. روی دکمه چک جدید کلیک کنید."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="14" Foreground="#FFAAAAAA" Visibility="Collapsed">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Cheques.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </DockPanel>
</UserControl>
