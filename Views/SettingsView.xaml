<UserControl x:Class="PosAccountingApp.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <StackPanel MaxWidth="800" HorizontalAlignment="Right" Margin="0,0,0,20">

            <!-- Theme -->
            <Border Style="{StaticResource CardBorder}" Padding="22">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="ظاهر برنامه" FontSize="17" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="پوسته برنامه" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="یکی از ۵ پوسته رنگی را انتخاب کنید" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <ComboBox ItemsSource="{Binding ThemeNames}" SelectedIndex="{Binding SelectedThemeIndex}"
                                      Width="220" HorizontalAlignment="Left" Padding="10,6" Margin="0,6,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="اعمال تم" Style="{StaticResource PrimaryButton}"
                                Command="{Binding ApplyThemeCommand}" VerticalAlignment="Bottom"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Font Size -->
            <Border Style="{StaticResource CardBorder}" Padding="22">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="&#xE8D2;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="اندازه فونت" FontSize="17" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="اندازه متن برنامه" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="اندازه فونت را تنظیم کنید" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <ComboBox ItemsSource="{Binding FontSizes}" SelectedItem="{Binding FontSize}"
                                      Width="120" HorizontalAlignment="Left" Padding="10,6" Margin="0,6,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="اعمال" Style="{StaticResource SuccessButton}"
                                Command="{Binding ApplyFontSizeCommand}" VerticalAlignment="Bottom"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- High Contrast -->
            <Border Style="{StaticResource CardBorder}" Padding="22">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="&#xE788;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="دسترسی‌پذیری" FontSize="17" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="کنتراست بالا" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="متن مشکی روی زمینه سفید برای بهتر دیدن" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="فعال/غیرفعال" Style="{StaticResource WarningButton}"
                                Command="{Binding ToggleHighContrastCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Shop Profile -->
            <Border Style="{StaticResource CardBorder}" Padding="22">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="پروفایل کسب‌وکار" FontSize="17" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="4">
                            <TextBlock Text="نام فروشگاه" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding BusinessName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4">
                            <TextBlock Text="تلفن" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding BusinessPhone, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Margin="4,10,4,0">
                        <TextBlock Text="آدرس" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding BusinessAddress, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="4,10,4,0">
                        <TextBlock Text="نوع کسب‌وکار" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                                  Width="240" HorizontalAlignment="Left" Padding="10,6"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Tax & Rounding -->
            <Border Style="{StaticResource CardBorder}" Padding="22">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="مالیات و گرد کردن" FontSize="17" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="4">
                            <TextBlock Text="درصد مالیات (VAT)" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding VatPercentage, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4">
                            <TextBlock Text="روش گرد کردن" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding RoundingModes}" SelectedItem="{Binding RoundingMode}"
                                      Width="200" HorizontalAlignment="Left" Padding="10,6"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="4">
                            <TextBlock Text="درصد کارمزد (املاک/خودرو)" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding CommissionPercentage, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4">
                            <TextBlock Text="نماد ارز" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding CurrencySymbol, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Receipt Settings -->
            <Border Style="{StaticResource CardBorder}" Padding="22">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="تنظیمات رسید" FontSize="17" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="4">
                            <TextBlock Text="سربرگ رسید" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ReceiptHeader, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4">
                            <TextBlock Text="پیام انتهای رسید" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ReceiptFooter, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="4">
                            <TextBlock Text="پیشوند شماره فاکتور" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding InvoicePrefix, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4">
                            <TextBlock Text="نحوه افزودن اطلاعات" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <ComboBox SelectedIndex="{Binding UsePopupForAdd, Converter={StaticResource BoolToVis}}"
                                      Width="200" HorizontalAlignment="Left" Padding="10,6"
                                      x:Name="AddModeCombo" SelectionChanged="AddMode_Changed">
                                <ComboBoxItem Content="پنجره پاپ‌آپ" Tag="True"/>
                                <ComboBoxItem Content="صفحه جداگانه" Tag="False"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Backup -->
            <Border Style="{StaticResource CardBorder}" Padding="22">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="پشتیبان‌گیری" FontSize="17" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </StackPanel>
                    <TextBlock Text="فایل پشتیبان در دسکتاپ ذخیره می‌شود" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="پشتیبان‌گیری" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                                Command="{Binding BackupDatabaseCommand}"/>
                        <Button Content="بازیابی" Style="{StaticResource DangerButton}"
                                Command="{Binding RestoreDatabaseCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Button Content="ذخیره تمام تنظیمات" Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Left" Margin="6,10,6,0" Padding="24,10"
                    FontSize="14" Command="{Binding SaveSettingsCommand}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
