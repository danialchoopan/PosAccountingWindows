<UserControl x:Class="PosAccountingApp.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.12*"/>
            <ColumnDefinition Width="0.76*"/>
            <ColumnDefinition Width="0.12*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="10,14">
            <StackPanel>
                <TextBlock Text="تنظیمات" FontSize="22" FontWeight="Bold"
                           Foreground="#FF0078D4" Margin="0,0,0,18"/>

                <!-- Theme -->
                <Border Style="{StaticResource CardBorder}" Padding="22">
                    <StackPanel>
                        <TextBlock Text="ظاهر برنامه" FontSize="16" FontWeight="Bold" Foreground="#FF0078D4" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="پوسته:" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="ThemeCombo" Width="240" Padding="10,6" SelectedIndex="0">
                                <ComboBoxItem Content="اقیانوس آبی"/>
                                <ComboBoxItem Content="سبز زمردی"/>
                                <ComboBoxItem Content="بنفش سلطنتی"/>
                                <ComboBoxItem Content="غروب نارنجی"/>
                                <ComboBoxItem Content="نیمه‌شب تاریک"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Font -->
                <Border Style="{StaticResource CardBorder}" Padding="22">
                    <StackPanel>
                        <TextBlock Text="اندازه فونت" FontSize="16" FontWeight="Bold" Foreground="#FF0078D4" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="اندازه:" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="FontSizeCombo" Width="120" Padding="10,6" SelectedIndex="2">
                                <ComboBoxItem Content="10"/>
                                <ComboBoxItem Content="12"/>
                                <ComboBoxItem Content="14"/>
                                <ComboBoxItem Content="16"/>
                                <ComboBoxItem Content="18"/>
                                <ComboBoxItem Content="20"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- High Contrast -->
                <Border Style="{StaticResource CardBorder}" Padding="22">
                    <StackPanel>
                        <TextBlock Text="دسترسی‌پذیری" FontSize="16" FontWeight="Bold" Foreground="#FF0078D4" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="کنتراست بالا:" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <CheckBox x:Name="HighContrastCheck" Content="فعال کردن کنتراست بالا"
                                      FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Shop Profile -->
                <Border Style="{StaticResource CardBorder}" Padding="22">
                    <StackPanel>
                        <TextBlock Text="پروفایل کسب‌وکار" FontSize="16" FontWeight="Bold" Foreground="#FF0078D4" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="4">
                                <TextBlock Text="نام فروشگاه" FontSize="12" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <TextBox x:Name="ShopNameBox"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4">
                                <TextBlock Text="تلفن" FontSize="12" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <TextBox x:Name="PhoneBox"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Margin="4,10,4,0">
                            <TextBlock Text="آدرس" FontSize="12" Foreground="#FF888888" Margin="0,0,0,4"/>
                            <TextBox x:Name="AddressBox"/>
                        </StackPanel>
                        <StackPanel Margin="4,10,4,0">
                            <TextBlock Text="نوع کسب‌وکار" FontSize="12" Foreground="#FF888888" Margin="0,0,0,4"/>
                            <ComboBox x:Name="ProfileCombo" Width="240" HorizontalAlignment="Left" Padding="10,6">
                                <ComboBoxItem Content="سوپرمارکت"/>
                                <ComboBoxItem Content="پوشاک"/>
                                <ComboBoxItem Content="املاک"/>
                                <ComboBoxItem Content="خودرو"/>
                                <ComboBoxItem Content="مصالح"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Tax -->
                <Border Style="{StaticResource CardBorder}" Padding="22">
                    <StackPanel>
                        <TextBlock Text="مالیات و گرد کردن" FontSize="16" FontWeight="Bold" Foreground="#FF0078D4" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="4">
                                <TextBlock Text="درصد مالیات (VAT)" FontSize="12" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <TextBox x:Name="VatBox"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4">
                                <TextBlock Text="درصد کارمزد" FontSize="12" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <TextBox x:Name="CommissionBox"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Add Mode -->
                <Border Style="{StaticResource CardBorder}" Padding="22">
                    <StackPanel>
                        <TextBlock Text="نحوه افزودن اطلاعات" FontSize="16" FontWeight="Bold" Foreground="#FF0078D4" Margin="0,0,0,10"/>
                        <ComboBox x:Name="AddModeCombo" Width="300" HorizontalAlignment="Left" Padding="10,6">
                            <ComboBoxItem Content="پنجره پاپ‌آپ" Tag="Popup"/>
                            <ComboBoxItem Content="صفحه جداگانه" Tag="SeparatePage"/>
                            <ComboBoxItem Content="در همان صفحه" Tag="Inline" IsSelected="True"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Receipt -->
                <Border Style="{StaticResource CardBorder}" Padding="22">
                    <StackPanel>
                        <TextBlock Text="تنظیمات رسید" FontSize="16" FontWeight="Bold" Foreground="#FF0078D4" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="4">
                                <TextBlock Text="سربرگ رسید" FontSize="12" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <TextBox x:Name="ReceiptHeaderBox"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4">
                                <TextBlock Text="پیام انتهای رسید" FontSize="12" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <TextBox x:Name="ReceiptFooterBox"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Backup -->
                <Border Style="{StaticResource CardBorder}" Padding="22">
                    <StackPanel>
                        <TextBlock Text="پشتیبان‌گیری و نمونه" FontSize="16" FontWeight="Bold" Foreground="#FF0078D4" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="پشتیبان‌گیری" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                                    Click="Backup_Click"/>
                            <Button Content="تولید داده نمونه" Style="{StaticResource WarningButton}"
                                    Click="Seed_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Status -->
                <TextBlock x:Name="StatusLabel" Text="" FontSize="14" FontWeight="Bold"
                           Foreground="#FF107C10" HorizontalAlignment="Center" Margin="0,10,0,0"
                           Visibility="Collapsed"/>

                <!-- Single Apply Button -->
                <Button Content="ذخیره و اعمال تنظیمات" Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Center" Margin="0,16,0,20" Padding="40,14"
                        FontSize="16" Click="Apply_Click"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
