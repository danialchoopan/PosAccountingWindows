<UserControl x:Class="PosAccountingApp.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.15*"/>
            <ColumnDefinition Width="0.70*"/>
            <ColumnDefinition Width="0.15*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="10,14">
            <StackPanel>
                <TextBlock Text="تنظیمات" FontSize="22" FontWeight="Bold"
                           Foreground="#FF0078D4" Margin="0,0,0,18"/>

                <!-- Theme -->
                <Border Style="{StaticResource CardBorder}" Padding="22">
                    <StackPanel>
                        <TextBlock Text="ظاهر برنامه" FontSize="16" FontWeight="Bold"
                                   Foreground="#FF0078D4" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="پوسته برنامه" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="یکی از ۵ پوسته رنگی را انتخاب کنید" FontSize="11" Foreground="#FF888888"/>
                                <ComboBox ItemsSource="{Binding ThemeNames}" SelectedIndex="{Binding SelectedThemeIndex}"
                                          Width="240" HorizontalAlignment="Left" Padding="10,6" Margin="0,6,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="اعمال تم" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ApplyThemeCommand}" VerticalAlignment="Bottom"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Font -->
                <Border Style="{StaticResource CardBorder}" Padding="22">
                    <StackPanel>
                        <TextBlock Text="اندازه فونت" FontSize="16" FontWeight="Bold"
                                   Foreground="#FF0078D4" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="اندازه متن برنامه" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding FontSizes}" SelectedItem="{Binding FontSize}"
                                          Width="120" HorizontalAlignment="Left" Padding="10,6"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="اعمال" Style="{StaticResource SuccessButton}"
                                    Command="{Binding ApplyFontSizeCommand}" VerticalAlignment="Bottom"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- High Contrast -->
                <Border Style="{StaticResource CardBorder}" Padding="22">
                    <StackPanel>
                        <TextBlock Text="دسترسی‌پذیری" FontSize="16" FontWeight="Bold"
                                   Foreground="#FF0078D4" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="کنتراست بالا" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="متن مشکی روی زمینه سفید" FontSize="11" Foreground="#FF888888"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="فعال/غیرفعال" Style="{StaticResource WarningButton}"
                                    Command="{Binding ToggleHighContrastCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Shop Profile -->
                <Border Style="{StaticResource CardBorder}" Padding="22">
                    <StackPanel>
                        <TextBlock Text="پروفایل کسب‌وکار" FontSize="16" FontWeight="Bold"
                                   Foreground="#FF0078D4" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="4">
                                <TextBlock Text="نام فروشگاه" FontSize="12" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding BusinessName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4">
                                <TextBlock Text="تلفن" FontSize="12" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding BusinessPhone, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Margin="4,10,4,0">
                            <TextBlock Text="آدرس" FontSize="12" Foreground="#FF888888" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding BusinessAddress, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="4,10,4,0">
                            <TextBlock Text="نوع کسب‌وکار" FontSize="12" Foreground="#FF888888" Margin="0,0,0,4"/>
                            <ComboBox SelectedItem="{Binding SelectedProfile}" Width="240" HorizontalAlignment="Left" Padding="10,6">
                                <ComboBoxItem Content="سوپرمارکت و خرده‌فروشی" Tag="Supermarket"/>
                                <ComboBoxItem Content="پوشاک و کیف و کفش" Tag="Boutique"/>
                                <ComboBoxItem Content="بنگاه املاک" Tag="RealEstate"/>
                                <ComboBoxItem Content="نمایشگاه خودرو" Tag="CarDealership"/>
                                <ComboBoxItem Content="فروشگاه مصالح ساختمانی" Tag="ConstructionMaterials"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Tax -->
                <Border Style="{StaticResource CardBorder}" Padding="22">
                    <StackPanel>
                        <TextBlock Text="مالیات و گرد کردن" FontSize="16" FontWeight="Bold"
                                   Foreground="#FF0078D4" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="4">
                                <TextBlock Text="درصد مالیات (VAT)" FontSize="12" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding VatPercentage, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4">
                                <TextBlock Text="روش گرد کردن" FontSize="12" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding RoundingModes}" SelectedItem="{Binding RoundingMode}"
                                          Width="200" HorizontalAlignment="Left" Padding="10,6"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="4">
                                <TextBlock Text="درصد کارمزد" FontSize="12" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding CommissionPercentage, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4">
                                <TextBlock Text="نماد ارز" FontSize="12" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding CurrencySymbol, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Add Mode -->
                <Border Style="{StaticResource CardBorder}" Padding="22">
                    <StackPanel>
                        <TextBlock Text="نحوه افزودن اطلاعات" FontSize="16" FontWeight="Bold"
                                   Foreground="#FF0078D4" Margin="0,0,0,10"/>
                        <TextBlock Text="تعیین کنید فرم افزودن در کجا نمایش داده شود" FontSize="12"
                                   Foreground="#FF888888" Margin="0,0,0,8"/>
                        <ComboBox SelectedIndex="{Binding AddModeIndex}"
                                  Width="300" HorizontalAlignment="Left" Padding="10,6">
                            <ComboBoxItem Content="پنجره پاپ‌آپ" Tag="Popup"/>
                            <ComboBoxItem Content="صفحه جداگانه" Tag="SeparatePage"/>
                            <ComboBoxItem Content="در همان صفحه" Tag="Inline"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Receipt -->
                <Border Style="{StaticResource CardBorder}" Padding="22">
                    <StackPanel>
                        <TextBlock Text="تنظیمات رسید" FontSize="16" FontWeight="Bold"
                                   Foreground="#FF0078D4" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="4">
                                <TextBlock Text="سربرگ رسید" FontSize="12" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding ReceiptHeader, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4">
                                <TextBlock Text="پیام انتهای رسید" FontSize="12" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding ReceiptFooter, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Margin="4,10,4,0">
                            <TextBlock Text="پیشوند شماره فاکتور" FontSize="12" Foreground="#FF888888" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding InvoicePrefix, UpdateSourceTrigger=PropertyChanged}"
                                     Width="160" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Backup -->
                <Border Style="{StaticResource CardBorder}" Padding="22">
                    <StackPanel>
                        <TextBlock Text="پشتیبان‌گیری و نمونه داده" FontSize="16" FontWeight="Bold"
                                   Foreground="#FF0078D4" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="پشتیبان‌گیری" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                                    Command="{Binding BackupDatabaseCommand}"/>
                            <Button Content="بازیابی" Style="{StaticResource DangerButton}" Margin="0,0,8,0"
                                    Command="{Binding RestoreDatabaseCommand}"/>
                            <Button Content="تولید داده نمونه" Style="{StaticResource WarningButton}"
                                    Command="{Binding SeedDataCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Button Content="ذخیره و اعمال تنظیمات" Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Center" Margin="0,16,0,8" Padding="30,12"
                        FontSize="15" Command="{Binding SaveSettingsCommand}"/>

                <TextBlock x:Name="StatusLabel" Text="" FontSize="13" FontWeight="SemiBold"
                           Foreground="#FF107C10" HorizontalAlignment="Center" Margin="0,4,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
