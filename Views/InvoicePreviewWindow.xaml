<Window x:Class="PosAccountingApp.Views.InvoicePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="پیش‌نمایش فاکتور"
        Width="500" Height="700"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        Background="White"
        Icon="{StaticResource AppIcon}">

    <DockPanel Margin="20">
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#FF107C10" CornerRadius="10" Padding="16,14" Margin="0,0,0,16">
            <Grid>
                <TextBlock Text="&#xE73E;  فاکتور فروش" FontFamily="Segoe MDL2 Assets"
                           FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                        Background="Transparent" BorderThickness="0"
                        Foreground="White" FontSize="16" HorizontalAlignment="Left"
                        Click="Close_Click"/>
            </Grid>
        </Border>

        <!-- Invoice Content -->
        <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" MaxHeight="450">
            <Border BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel x:Name="InvoiceContent">
                    <!-- Invoice Header -->
                    <TextBlock x:Name="ShopNameLabel" Text="فروشگاه" FontSize="18" FontWeight="Bold"
                               Foreground="#FF0078D4" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="InvoiceNumLabel" Text="شماره فاکتور: " FontSize="12"
                               Foreground="#FF888888" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock x:Name="DateLabel" Text="تاریخ: " FontSize="12"
                               Foreground="#FF888888" HorizontalAlignment="Center" Margin="0,2,0,12"/>
                    <Separator Background="#FFE0E0E0" Margin="0,0,0,10"/>

                    <!-- Items -->
                    <TextBlock Text="آیتم‌ها:" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <DataGrid x:Name="ItemsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="کالا" Binding="{Binding ProductTitle}" Width="*"/>
                            <DataGridTextColumn Header="تعداد" Binding="{Binding Quantity}" Width="60"/>
                            <DataGridTextColumn Header="قیمت" Binding="{Binding UnitPrice}" Width="80"/>
                            <DataGridTextColumn Header="جمع" Binding="{Binding Subtotal}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Separator Background="#FFE0E0E0" Margin="0,10,0,10"/>

                    <!-- Totals -->
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="جمع کل:" HorizontalAlignment="Left" FontWeight="SemiBold"/>
                        <TextBlock x:Name="SubtotalLabel" Text="0" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="مالیات:" HorizontalAlignment="Left" Foreground="#FF888888"/>
                        <TextBlock x:Name="TaxLabel" Text="0" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,6,0,0">
                        <TextBlock Text="مبلغ قابل پرداخت:" HorizontalAlignment="Left" FontWeight="Bold" FontSize="14"/>
                        <TextBlock x:Name="TotalLabel" Text="0" HorizontalAlignment="Right"
                                   FontSize="16" FontWeight="Bold" Foreground="#FF107C10"/>
                    </Grid>
                    <Separator Background="#FFE0E0E0" Margin="0,10,0,8"/>
                    <TextBlock x:Name="StatusLabel" Text="وضعیت: پرداخت شده" FontSize="12"
                               Foreground="#FF107C10" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="ستاره‌دار کردن" Style="{StaticResource WarningButton}" Margin="0,0,8,0"
                    Click="Star_Click" x:Name="StarBtn"/>
            <Button Content="چاپ" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                    Click="Print_Click"/>
            <Button Content="بستن" Style="{StaticResource OutlineButton}"
                    Click="Close_Click"/>
        </StackPanel>
    </DockPanel>
</Window>
