<UserControl x:Class="PosAccountingApp.Views.CategoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:PosAccountingApp.Controls">

    <DockPanel Margin="14">
        <Border DockPanel.Dock="Top" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,0" VerticalContentAlignment="Center"/>
                <Button Grid.Column="1" Content="X" Style="{StaticResource DangerButton}"
                        Padding="8,6" Margin="0,0,6,0"
                        Command="{Binding ClearSearchCommand}"/>
                <Button Grid.Column="2" Content="دسته جدید"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ToggleAddPanelCommand}"/>
            </Grid>
        </Border>

        <!-- Add Panel -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}"
                Visibility="{Binding IsAddPanelOpen, Converter={StaticResource BoolToVis}}"
                Margin="0,0,0,10" Padding="18">
            <StackPanel>
                <TextBlock Text="افزودن دسته جدید" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"
                           Foreground="{DynamicResource AccentBrush}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="4">
                        <TextBlock Text="نام دسته" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="4">
                        <TextBlock Text="توضیحات" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="4">
                        <TextBlock Text="ترتیب" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditSortOrder, UpdateSourceTrigger=PropertyChanged}" FlowDirection="LeftToRight"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="4">
                        <TextBlock Text="آیکون" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <Border BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="6" Background="White">
                            <ComboBox ItemsSource="{Binding AvailableIcons}" SelectedItem="{Binding EditIcon}" Padding="8,5">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="4">
                        <TextBlock Text="دسته والد (اختیاری)" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <Border BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="6" Background="White">
                            <ComboBox ItemsSource="{Binding ParentCategories}" SelectedItem="{Binding EditParentCategory}"
                                      DisplayMemberPath="Name" Padding="8,5"/>
                        </Border>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
                    <Button Content="ذخیره" Style="{StaticResource PrimaryButton}" Margin="0,0,6,0"
                            Command="{Binding SaveCategoryCommand}"/>
                    <Button Content="انصراف" Style="{StaticResource DangerButton}"
                            Command="{Binding CancelEditCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid>
            <DataGrid ItemsSource="{Binding Categories}">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="آیکون" Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="نام" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="توضیح" Binding="{Binding Description}" Width="180"/>
                    <DataGridTextColumn Header="ترتیب" Binding="{Binding SortOrder}" Width="60"/>
                    <DataGridTemplateColumn Header="حذف" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="X" Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource ErrorBrush}" Cursor="Hand" FontSize="11"
                                        Command="{Binding DataContext.DeleteCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
            <TextBlock Text="هنوز دسته‌ای ثبت نشده."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Visibility="Collapsed">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Categories.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </DockPanel>
</UserControl>
