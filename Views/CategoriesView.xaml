<UserControl x:Class="PosAccountingApp.Views.CategoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosAccountingApp.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <DockPanel Margin="14">
        <Border DockPanel.Dock="Top" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Tag="&#xE721; &#x062C;&#x0633;&#x062A;&#x062C;&#x0648;&#x06CC; &#x062F;&#x0633;&#x062A;&#x0647;..." Margin="0,0,8,0" VerticalContentAlignment="Center"/>
                <Button Grid.Column="1" Content="X" Style="{StaticResource DangerButton}"
                        Padding="8,6" Margin="0,0,6,0"
                        Command="{Binding ClearSearchCommand}"/>
                <Button Grid.Column="2" Content="&#xE710;  &#x062F;&#x0633;&#x062A;&#x0647; &#x062C;&#x062F;&#x06CC;&#x062F;"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ToggleAddPanelCommand}"/>
            </Grid>
        </Border>

        <!-- Add Panel -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}"
                Visibility="{Binding IsAddPanelOpen, Converter={StaticResource BoolToVis}}"
                Margin="0,0,0,10" Padding="18">
            <StackPanel>
                <TextBlock Text="&#x0627;&#x0641;&#x0632;&#x0648;&#x062F;&#x0646; &#x062F;&#x0633;&#x062A;&#x0647; &#x062C;&#x062F;&#x06CC;&#x062F;" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"
                           Foreground="{DynamicResource AccentBrush}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="4">
                        <TextBlock Text="&#x0646;&#x0627;&#x0645; &#x062F;&#x0633;&#x062A;&#x0647;" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="4">
                        <TextBlock Text="&#x062A;&#x0648;&#x0636;&#x06CC;&#x062D;&#x0627;&#x062A;" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="4">
                        <TextBlock Text="&#x0622;&#x06CC;&#x06A9;&#x0648;&#x0646;" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <ComboBox ItemsSource="{Binding AvailableIcons}" SelectedItem="{Binding EditIcon}" Padding="8,4"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="4">
                        <TextBlock Text="&#x062A;&#x0631;&#x062A;&#x06CC;&#x0628;" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditSortOrder, UpdateSourceTrigger=PropertyChanged}" FlowDirection="LeftToRight"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
                    <Button Content="&#x0630;&#x062E;&#x06CC;&#x0631;&#x0647;" Style="{StaticResource PrimaryButton}" Margin="0,0,6,0"
                            Command="{Binding SaveCategoryCommand}"/>
                    <Button Content="&#x0627;&#x0646;&#x0635;&#x0631;&#x0627;&#x0641;" Style="{StaticResource DangerButton}"
                            Command="{Binding CancelEditCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Grid or Empty -->
        <Grid>
            <DataGrid ItemsSource="{Binding Categories}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="&#x0622;&#x06CC;&#x06A9;&#x0648;&#x0646;" Binding="{Binding Icon}" Width="50"/>
                    <DataGridTextColumn Header="&#x0646;&#x0627;&#x0645;" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="&#x062A;&#x0648;&#x0636;&#x06CC;&#x062D;" Binding="{Binding Description}" Width="200"/>
                    <DataGridTextColumn Header="&#x062A;&#x0631;&#x062A;&#x06CC;&#x0628;" Binding="{Binding SortOrder}" Width="60"/>
                    <DataGridTemplateColumn Header="&#x062D;&#x0630;&#x0641;" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="&#x2716;" Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource ErrorBrush}" Cursor="Hand" FontSize="11"
                                        Command="{Binding DataContext.DeleteCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
            <TextBlock Text="&#x0647;&#x0646;&#x0648;&#x0632; &#x062F;&#x0633;&#x062A;&#x0647;&#x0627;&#x06CC; &#x06CC; &#x062C;&#x0633;&#x062A;&#x0647; &#x0646;&#x0634;&#x062F;&#x0647; &#x0627;&#x0633;&#x062A;."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Visibility="Collapsed">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Categories.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </DockPanel>
</UserControl>
