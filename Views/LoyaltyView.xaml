<UserControl x:Class="PosAccountingApp.Views.LoyaltyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosAccountingApp.Converters"
             xmlns:ctrl="clr-namespace:PosAccountingApp.Controls">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:EnumToPersianConverter x:Key="EnumToPersian"/>
    </UserControl.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Customer Tiers List -->
        <DockPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock DockPanel.Dock="Top" Text="سیستم وفاداری مشتریان" FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,12"/>

            <!-- Tier Legend -->
            <Border DockPanel.Dock="Top" Background="#FFF5F7FA" BorderBrush="#FFE0E0E0"
                    BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#FFCD7F32" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                        <TextBlock Text="برنزی" FontSize="11" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Background="#FFC0C0C0" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                        <TextBlock Text="نقره‌ای" FontSize="11" FontWeight="Bold" Foreground="#FF333"/>
                    </Border>
                    <Border Background="#FFFFD700" CornerRadius="4" Padding="8,4">
                        <TextBlock Text="طلایی" FontSize="11" FontWeight="Bold" Foreground="#FF333"/>
                    </Border>
                </StackPanel>
            </Border>

            <Grid>
                <DataGrid ItemsSource="{Binding CustomerTiers}" MouseDoubleClick="TierGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="نام مشتری" Binding="{Binding Customer.Name}" Width="*"/>
                        <DataGridTemplateColumn Header="سطح" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Tier}" Value="Bronze">
                                                        <Setter Property="Background" Value="#FFCD7F32"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Tier}" Value="Silver">
                                                        <Setter Property="Background" Value="#FFC0C0C0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Tier}" Value="Gold">
                                                        <Setter Property="Background" Value="#FFFFD700"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Tier, Converter={StaticResource EnumToPersian}}"
                                                   FontSize="10" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="امتیاز" Binding="{Binding Points}" Width="80"/>
                        <DataGridTextColumn Header="تخفیف" Binding="{Binding Discount}" Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
                <TextBlock Text="هنوز مشتری ثبت نشده."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Visibility="Collapsed">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CustomerTiers.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </DockPanel>

        <!-- Right: Customer Detail -->
        <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="14">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" FontSize="15" FontWeight="Bold" Margin="0,0,0,10"
                           Foreground="{DynamicResource AccentBrush}">جزئیات وفاداری</TextBlock>

                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <Border Background="#FF0078D4" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="مشتری:" FontSize="12" Foreground="#CCFFFFFF" HorizontalAlignment="Left"/>
                                <TextBlock Text="{Binding SelectedCustomer.Name}" FontSize="14" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="امتیاز:" FontSize="12" Foreground="#CCFFFFFF" HorizontalAlignment="Left"/>
                                <TextBlock Text="{Binding CustomerPoints}" FontSize="14" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="تخفیف:" FontSize="12" Foreground="#CCFFFFFF" HorizontalAlignment="Left"/>
                                <TextBlock Text="{Binding TierDiscount, StringFormat={}{0}%}" FontSize="14" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Redeem Points -->
                    <TextBlock Text="استفاده از امتیاز" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="تعداد امتیاز" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding RedeemPointsAmount, UpdateSourceTrigger=PropertyChanged}"
                                     FlowDirection="LeftToRight"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="استفاده" Style="{StaticResource SuccessButton}"
                                VerticalAlignment="Bottom" Margin="6,0,0,0"
                                Command="{Binding RedeemPointsCommand}"/>
                    </Grid>
                </StackPanel>

                <!-- Transaction History -->
                <TextBlock DockPanel.Dock="Top" Text="تاریخچه امتیاز" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <DataGrid ItemsSource="{Binding Transactions}" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="تاریخ" Binding="{Binding TransactionDate, StringFormat=yyyy/MM/dd}" Width="70"/>
                        <DataGridTextColumn Header="نوع" Binding="{Binding Type}" Width="60"/>
                        <DataGridTextColumn Header="امتیاز" Binding="{Binding Points}" Width="60"/>
                        <DataGridTextColumn Header="توضیحات" Binding="{Binding Description}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
