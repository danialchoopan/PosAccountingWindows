<UserControl x:Class="PosAccountingApp.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel Margin="14">
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="نوع گزارش:" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="#FF888888"/>
                    <ComboBox ItemsSource="{Binding ReportTypes}"
                              SelectedItem="{Binding SelectedReportType}" Width="160"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0">
                    <TextBlock Text="از:" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="#FF888888"/>
                    <DatePicker SelectedDate="{Binding ReportStartDate}" Width="140"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0">
                    <TextBlock Text="تا:" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="#FF888888"/>
                    <DatePicker SelectedDate="{Binding ReportEndDate}" Width="140"/>
                </StackPanel>
                <Button Grid.Column="3" Content="نمایش گزارش"
                        Style="{StaticResource PrimaryButton}"/>
            </Grid>
        </Border>

        <Border Style="{StaticResource CardBorder}" Margin="0,10,0,0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40,0,40">
                <TextBlock Text="گزارشات" FontSize="28" FontWeight="Bold"
                           Foreground="#FFCCCCCC" HorizontalAlignment="Center"/>
                <TextBlock Text="نوع گزارش را انتخاب کرده و روی نمایش کلیک کنید"
                           FontSize="13" Foreground="#FFAAAAAA"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>
    </DockPanel>
</UserControl>
