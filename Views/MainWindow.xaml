<Window x:Class="PosAccountingApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PosAccountingApp.ViewModels"
        xmlns:views="clr-namespace:PosAccountingApp.Views"
        xmlns:conv="clr-namespace:PosAccountingApp.Converters"
        Title="سیستم مدیریت فروش و حسابداری"
        Width="1400" Height="800"
        MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        FlowDirection="RightToLeft"
        Background="{StaticResource BgBrush}"
        Icon="{StaticResource AppIcon}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:DecimalToPersianStringConverter x:Key="DecToPersian"/>
        <conv:JalaliDateConverter x:Key="JalaliDate"/>
        <conv:EnumToPersianConverter x:Key="EnumToPersian"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis2"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="F1" Command="{Binding NavigateToCommand}" CommandParameter="POS"/>
        <KeyBinding Key="F2" Command="{Binding NavigateToCommand}" CommandParameter="Products"/>
        <KeyBinding Key="F3" Command="{Binding NavigateToCommand}" CommandParameter="Cheques"/>
        <KeyBinding Key="F4" Command="{Binding NavigateToCommand}" CommandParameter="Categories"/>
        <KeyBinding Key="F9" Command="{Binding NavigateToCommand}" CommandParameter="Reports"/>
        <KeyBinding Key="G" Modifiers="Control" Command="{Binding OpenGlobalSearchCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="180" MaxWidth="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBgBrush}"
                BorderBrush="{StaticResource CustomBorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Brand -->
                <Border DockPanel.Dock="Top" Padding="14,20" Margin="0,0,0,6">
                    <StackPanel>
                        <TextBlock Text="حسابداری" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="ShopNameLabel" Text="" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>

                <!-- User Card -->
                <Border DockPanel.Dock="Top" Background="{StaticResource CardBgBrush}"
                        BorderBrush="{StaticResource CustomBorderBrush}" BorderThickness="1"
                        CornerRadius="8" Margin="10,0,10,12" Padding="10">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="34" Height="34" CornerRadius="17"
                                Background="{StaticResource AccentBrush}" Margin="0,0,10,0">
                            <TextBlock Text="م" FontSize="15" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentUser}" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding StatusMessage}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Nav -->
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" MaxHeight="520">
                    <StackPanel Margin="4,0">
                        <RadioButton Style="{StaticResource SidebarButton}" IsChecked="True"
                                     Content="داشبورد"
                                     Command="{Binding NavigateToCommand}" CommandParameter="Dashboard"/>
                        <RadioButton Style="{StaticResource SidebarButton}"
                                     Content="صندوق فروشگاهی (F1)"
                                     Command="{Binding NavigateToCommand}" CommandParameter="POS"/>
                        <RadioButton Style="{StaticResource SidebarButton}"
                                     Content="کالاها و خدمات (F2)"
                                     Command="{Binding NavigateToCommand}" CommandParameter="Products"/>
                        <RadioButton Style="{StaticResource SidebarButton}"
                                     Content="دسته‌بندی‌ها (F4)"
                                     Command="{Binding NavigateToCommand}" CommandParameter="Categories"/>
                        <RadioButton Style="{StaticResource SidebarButton}"
                                     Content="مشتریان"
                                     Command="{Binding NavigateToCommand}" CommandParameter="Customers"/>
                        <RadioButton Style="{StaticResource SidebarButton}"
                                     Content="خزانه‌داری و چک (F3)"
                                     Command="{Binding NavigateToCommand}" CommandParameter="Cheques"/>
                        <RadioButton Style="{StaticResource SidebarButton}"
                                     Content="هزینه‌ها"
                                     Command="{Binding NavigateToCommand}" CommandParameter="Expenses"/>
                        <RadioButton Style="{StaticResource SidebarButton}"
                                     Content="گزارشات (F9)"
                                     Command="{Binding NavigateToCommand}" CommandParameter="Reports"/>
                        <RadioButton Style="{StaticResource SidebarButton}"
                                     Content="حسابداری"
                                     Command="{Binding NavigateToCommand}" CommandParameter="Accounting"/>
                        <RadioButton Style="{StaticResource SidebarButton}"
                                     Content="تامین‌کنندگان"
                                     Command="{Binding NavigateToCommand}" CommandParameter="Suppliers"/>
                        <RadioButton Style="{StaticResource SidebarButton}"
                                     Content="مدیریت انبار"
                                     Command="{Binding NavigateToCommand}" CommandParameter="Inventory"/>
                        <RadioButton Style="{StaticResource SidebarButton}"
                                     Content="فروش‌ها"
                                     Command="{Binding NavigateToCommand}" CommandParameter="Sells"/>
                        <RadioButton x:Name="UsersNavBtn" Style="{StaticResource SidebarButton}"
                                     Content="مدیریت کاربران"
                                     Command="{Binding NavigateToCommand}" CommandParameter="Users"
                                     Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Bottom -->
                <StackPanel DockPanel.Dock="Bottom" Margin="4,0,4,12">
                    <RadioButton x:Name="HelpNavBtn" Style="{StaticResource SidebarButton}"
                                 Content="&#xE897;  راهنما"
                                 Click="Help_Click"/>
                    <RadioButton Style="{StaticResource SidebarButton}"
                                 Content="&#xE722;  اسکن بارکد"
                                 Click="ScanBarcode_Click"/>
                    <RadioButton Style="{StaticResource SidebarButton}"
                                 Content="&#xE713;  تنظیمات"
                                 Command="{Binding NavigateToCommand}" CommandParameter="Settings"/>
                </StackPanel>
                <Border/>
            </DockPanel>
        </Border>

        <!-- Content -->
        <DockPanel Grid.Column="1">
            <!-- Top Bar -->
            <Border DockPanel.Dock="Top" Background="{StaticResource CardBgBrush}"
                    BorderBrush="{StaticResource CustomBorderBrush}" BorderThickness="0,0,0,1"
                    Padding="20,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding CurrentViewTitle}"
                               FontSize="19" FontWeight="Bold" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{StaticResource BadgeBgBrush}" CornerRadius="10"
                                Padding="10,4" Margin="0,0,8,0">
                            <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                                       Foreground="{StaticResource BadgeFgBrush}"/>
                        </Border>
                        <Button Content="&#xE793;  جستجو  (Ctrl+G)"
                                FontFamily="Vazirmatn, Segoe UI" FontSize="12"
                                Style="{StaticResource OutlineButton}"
                                Command="{Binding OpenGlobalSearchCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Status Bar -->
            <Border DockPanel.Dock="Bottom" Background="{StaticResource SidebarBgBrush}"
                    BorderBrush="{StaticResource CustomBorderBrush}" BorderThickness="0,1,0,0"
                    Padding="16,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="F1 صندوق  |  F2 کالا  |  F4 دسته‌بندی  |  F3 چک  |  Ctrl+G جستجو"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding CurrentViewTitle}"
                               FontSize="11" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- View -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentView}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                        <views:DashboardView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ProductsViewModel}">
                        <views:ProductsView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:CustomersViewModel}">
                        <views:CustomersView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:PosViewModel}">
                        <views:PosView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ChequesViewModel}">
                        <views:ChequesView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ExpensesViewModel}">
                        <views:ExpensesView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
                        <views:ReportsView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                        <views:SettingsView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:UsersViewModel}">
                        <views:UsersView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:CategoriesViewModel}">
                        <views:CategoriesView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:AccountingViewModel}">
                        <views:AccountingView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:SupplierViewModel}">
                        <views:SupplierView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:InventoryViewModel}">
                        <views:InventoryView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:SellsViewModel}">
                        <views:SellsView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:LoyaltyViewModel}">
                        <views:LoyaltyView/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </DockPanel>
    </Grid>
</Window>
