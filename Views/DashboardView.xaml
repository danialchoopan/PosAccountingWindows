<UserControl x:Class="PosAccountingApp.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosAccountingApp.Converters">

    <UserControl.Resources>
        <conv:DecimalToPersianStringConverter x:Key="DecToPersian"/>
        <conv:EnumToPersianConverter x:Key="EnumToPersian"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel Margin="8" MaxWidth="1400" HorizontalAlignment="Center">

            <TextBlock Text="داشبورد" FontSize="26" FontWeight="Bold" Margin="8,0,8,20"
                       Foreground="{DynamicResource AccentBrush}"/>

            <!-- Row 1 -->
            <UniformGrid Columns="3" Margin="0,0,0,14">
                <Border Background="#FF0078D4" CornerRadius="10" Padding="18,16" Margin="6">
                    <StackPanel>
                        <TextBlock Text="فروش امروز" FontSize="12" Foreground="#CCFFFFFF"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,8,0,0"
                                   Text="{Binding TotalSalesToday}"/>
                    </StackPanel>
                </Border>
                <Border Background="#FF107C10" CornerRadius="10" Padding="18,16" Margin="6">
                    <StackPanel>
                        <TextBlock Text="درآمد امروز" FontSize="12" Foreground="#CCFFFFFF"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,8,0,0"
                                   Text="{Binding TotalRevenueToday}"/>
                    </StackPanel>
                </Border>
                <Border Background="#FFFF8C00" CornerRadius="10" Padding="18,16" Margin="6">
                    <StackPanel>
                        <TextBlock Text="مشتریان" FontSize="12" Foreground="#CCFFFFFF"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,8,0,0"
                                   Text="{Binding TotalCustomers}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Row 2 -->
            <UniformGrid Columns="3" Margin="0,0,0,14">
                <Border Background="#FF7C3AED" CornerRadius="10" Padding="18,16" Margin="6">
                    <StackPanel>
                        <TextBlock Text="کالاها" FontSize="12" Foreground="#CCFFFFFF"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,8,0,0"
                                   Text="{Binding TotalProducts}"/>
                    </StackPanel>
                </Border>
                <Border Background="#FFD13438" CornerRadius="10" Padding="18,16" Margin="6">
                    <StackPanel>
                        <TextBlock Text="چک‌های در انتظار" FontSize="12" Foreground="#CCFFFFFF"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,8,0,0"
                                   Text="{Binding PendingCheques}"/>
                    </StackPanel>
                </Border>
                <Border Background="#FF0D9488" CornerRadius="10" Padding="18,16" Margin="6">
                    <StackPanel>
                        <TextBlock Text="هشدار موجودی" FontSize="12" Foreground="#CCFFFFFF"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,8,0,0"
                                   Text="{Binding LowStockItems}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Quick Actions Row 1 -->
            <TextBlock Text="دسترسی سریع" FontSize="17" FontWeight="Bold" Margin="8,8,8,12"/>
            <UniformGrid Columns="4" Margin="0,0,0,8">
                <Button Content="صندوق فروش (F1)" Style="{StaticResource PrimaryButton}" Margin="6"
                        Click="NavigateToPOS"/>
                <Button Content="کالاها و خدمات (F2)" Style="{StaticResource SuccessButton}" Margin="6"
                        Click="NavigateToProducts"/>
                <Button Content="مشتریان" Style="{StaticResource WarningButton}" Margin="6"
                        Click="NavigateToCustomers"/>
                <Button Content="خزانه‌داری و چک (F3)" Style="{StaticResource DangerButton}" Margin="6"
                        Click="NavigateToCheques"/>
            </UniformGrid>

            <!-- Quick Actions Row 2 -->
            <UniformGrid Columns="4" Margin="0,0,0,8">
                <Button Content="دسته‌بندی‌ها (F4)" Style="{StaticResource PrimaryButton}" Margin="6"
                        Click="NavigateToCategories"/>
                <Button Content="هزینه‌ها" Style="{StaticResource WarningButton}" Margin="6"
                        Click="NavigateToExpenses"/>
                <Button Content="تامین‌کنندگان" Style="{StaticResource SuccessButton}" Margin="6"
                        Click="NavigateToSuppliers"/>
                <Button Content="وفاداری مشتریان" Style="{StaticResource DangerButton}" Margin="6"
                        Click="NavigateToLoyalty"/>
            </UniformGrid>

            <!-- Quick Actions Row 3 -->
            <UniformGrid Columns="4">
                <Button Content="حسابداری" Style="{StaticResource PrimaryButton}" Margin="6"
                        Click="NavigateToAccounting"/>
                <Button Content="گزارشات (F9)" Style="{StaticResource WarningButton}" Margin="6"
                        Click="NavigateToReports"/>
                <Button Content="مدیریت کاربران" Style="{StaticResource SuccessButton}" Margin="6"
                        Click="NavigateToUsers"/>
                <Button Content="تنظیمات" Style="{StaticResource OutlineButton}" Margin="6"
                        Click="NavigateToSettings"/>
            </UniformGrid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
