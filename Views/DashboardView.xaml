<UserControl x:Class="PosAccountingApp.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosAccountingApp.Converters">

    <UserControl.Resources>
        <conv:DecimalToPersianStringConverter x:Key="DecToPersian"/>
        <conv:EnumToPersianConverter x:Key="EnumToPersian"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel Margin="8" MaxWidth="1400" HorizontalAlignment="Center">

            <TextBlock Text="داشبورد" FontSize="26" FontWeight="Bold" Margin="8,0,8,20"
                       Foreground="{StaticResource AccentBrush}"/>

            <!-- Row 1 -->
            <UniformGrid Columns="3" Margin="0,0,0,14">
                <Border Background="#FF0078D4" CornerRadius="10" Padding="18,16" Margin="6">
                    <StackPanel>
                        <TextBlock Text="فروش امروز" FontSize="12" Foreground="#CCFFFFFF"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,8,0,0"
                                   Text="{Binding TotalSalesToday}"/>
                    </StackPanel>
                </Border>
                <Border Background="#FF107C10" CornerRadius="10" Padding="18,16" Margin="6">
                    <StackPanel>
                        <TextBlock Text="درآمد امروز" FontSize="12" Foreground="#CCFFFFFF"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,8,0,0"
                                   Text="{Binding TotalRevenueToday}"/>
                    </StackPanel>
                </Border>
                <Border Background="#FFFF8C00" CornerRadius="10" Padding="18,16" Margin="6">
                    <StackPanel>
                        <TextBlock Text="مشتریان" FontSize="12" Foreground="#CCFFFFFF"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,8,0,0"
                                   Text="{Binding TotalCustomers}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Row 2 -->
            <UniformGrid Columns="3" Margin="0,0,0,14">
                <Border Background="#FF7C3AED" CornerRadius="10" Padding="18,16" Margin="6">
                    <StackPanel>
                        <TextBlock Text="کالاها" FontSize="12" Foreground="#CCFFFFFF"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,8,0,0"
                                   Text="{Binding TotalProducts}"/>
                    </StackPanel>
                </Border>
                <Border Background="#FFD13438" CornerRadius="10" Padding="18,16" Margin="6">
                    <StackPanel>
                        <TextBlock Text="چک‌های در انتظار" FontSize="12" Foreground="#CCFFFFFF"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,8,0,0"
                                   Text="{Binding PendingCheques}"/>
                    </StackPanel>
                </Border>
                <Border Background="#FF0D9488" CornerRadius="10" Padding="18,16" Margin="6">
                    <StackPanel>
                        <TextBlock Text="هشدار موجودی" FontSize="12" Foreground="#CCFFFFFF"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,8,0,0"
                                   Text="{Binding LowStockItems}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Quick Actions Row 1 -->
            <TextBlock Text="دسترسی سریع" FontSize="17" FontWeight="Bold" Margin="8,8,8,12"/>
            <UniformGrid Columns="4" Margin="0,0,0,8">
                <Button Content="صندوق فروش (F1)" Margin="6"
                        Background="{StaticResource AccentBrush}" Foreground="White"
                        FontFamily="Vazirmatn, Segoe UI" FontSize="13" FontWeight="SemiBold"
                        Padding="12,10" Cursor="Hand" Click="NavigateToPOS"/>
                <Button Content="کالاها و خدمات (F2)" Margin="6"
                        Background="{StaticResource SuccessBrush}" Foreground="White"
                        FontFamily="Vazirmatn, Segoe UI" FontSize="13" FontWeight="SemiBold"
                        Padding="12,10" Cursor="Hand" Click="NavigateToProducts"/>
                <Button Content="مشتریان" Margin="6"
                        Background="{StaticResource WarningBrush}" Foreground="White"
                        FontFamily="Vazirmatn, Segoe UI" FontSize="13" FontWeight="SemiBold"
                        Padding="12,10" Cursor="Hand" Click="NavigateToCustomers"/>
                <Button Content="خزانه‌داری و چک (F3)" Margin="6"
                        Background="{StaticResource ErrorBrush}" Foreground="White"
                        FontFamily="Vazirmatn, Segoe UI" FontSize="13" FontWeight="SemiBold"
                        Padding="12,10" Cursor="Hand" Click="NavigateToCheques"/>
            </UniformGrid>

            <!-- Quick Actions Row 2 -->
            <UniformGrid Columns="4" Margin="0,0,0,8">
                <Button Content="دسته‌بندی‌ها (F4)" Margin="6"
                        Background="{StaticResource AccentBrush}" Foreground="White"
                        FontFamily="Vazirmatn, Segoe UI" FontSize="13" FontWeight="SemiBold"
                        Padding="12,10" Cursor="Hand" Click="NavigateToCategories"/>
                <Button Content="هزینه‌ها" Margin="6"
                        Background="{StaticResource WarningBrush}" Foreground="White"
                        FontFamily="Vazirmatn, Segoe UI" FontSize="13" FontWeight="SemiBold"
                        Padding="12,10" Cursor="Hand" Click="NavigateToExpenses"/>
                <Button Content="تامین‌کنندگان" Margin="6"
                        Background="{StaticResource SuccessBrush}" Foreground="White"
                        FontFamily="Vazirmatn, Segoe UI" FontSize="13" FontWeight="SemiBold"
                        Padding="12,10" Cursor="Hand" Click="NavigateToSuppliers"/>
            </UniformGrid>

            <!-- Quick Actions Row 3 -->
            <UniformGrid Columns="4">
                <Button Content="حسابداری" Margin="6"
                        Background="{StaticResource AccentBrush}" Foreground="White"
                        FontFamily="Vazirmatn, Segoe UI" FontSize="13" FontWeight="SemiBold"
                        Padding="12,10" Cursor="Hand" Click="NavigateToAccounting"/>
                <Button Content="گزارشات (F9)" Margin="6"
                        Background="{StaticResource WarningBrush}" Foreground="White"
                        FontFamily="Vazirmatn, Segoe UI" FontSize="13" FontWeight="SemiBold"
                        Padding="12,10" Cursor="Hand" Click="NavigateToReports"/>
                <Button Content="مدیریت کاربران" Margin="6"
                        Background="{StaticResource SuccessBrush}" Foreground="White"
                        FontFamily="Vazirmatn, Segoe UI" FontSize="13" FontWeight="SemiBold"
                        Padding="12,10" Cursor="Hand" Click="NavigateToUsers"/>
                <Button Content="تنظیمات" Margin="6"
                        Background="{StaticResource CustomBorderBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                        FontFamily="Vazirmatn, Segoe UI" FontSize="13" FontWeight="SemiBold"
                        Padding="12,10" Cursor="Hand" Click="NavigateToSettings"/>
            </UniformGrid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
