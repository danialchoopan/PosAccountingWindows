<UserControl x:Class="PosAccountingApp.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel Margin="8" MaxWidth="1200" HorizontalAlignment="Center">

            <TextBlock Text="داشبورد" FontSize="26" FontWeight="Bold" Margin="8,0,8,20"
                       Foreground="{DynamicResource AccentBrush}"/>

            <!-- Stats Cards Row 1 -->
            <UniformGrid Columns="3" Margin="0,0,0,14">
                <!-- Sales Today - Blue -->
                <Border Background="#FF0078D4" CornerRadius="10" Padding="18,16" Margin="6">
                    <StackPanel>
                        <TextBlock Text="&#xE74C;  فروش امروز" FontFamily="Segoe MDL2 Assets"
                                   FontSize="12" Foreground="#CCFFFFFF"/>
                        <TextBlock Text="۰ فاکتور" FontSize="28" FontWeight="Bold"
                                   Foreground="White" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Revenue - Green -->
                <Border Background="#FF107C10" CornerRadius="10" Padding="18,16" Margin="6">
                    <StackPanel>
                        <TextBlock Text="&#xE9D9;  درآمد امروز" FontFamily="Segoe MDL2 Assets"
                                   FontSize="12" Foreground="#CCFFFFFF"/>
                        <TextBlock Text="۰ ریال" FontSize="28" FontWeight="Bold"
                                   Foreground="White" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Customers - Orange -->
                <Border Background="#FFFF8C00" CornerRadius="10" Padding="18,16" Margin="6">
                    <StackPanel>
                        <TextBlock Text="&#xE77B;  مشتریان" FontFamily="Segoe MDL2 Assets"
                                   FontSize="12" Foreground="#CCFFFFFF"/>
                        <TextBlock Text="۰" FontSize="28" FontWeight="Bold"
                                   Foreground="White" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Stats Cards Row 2 -->
            <UniformGrid Columns="3" Margin="0,0,0,14">
                <!-- Products - Purple -->
                <Border Background="#FF7C3AED" CornerRadius="10" Padding="18,16" Margin="6">
                    <StackPanel>
                        <TextBlock Text="&#xE71C;  کالاها" FontFamily="Segoe MDL2 Assets"
                                   FontSize="12" Foreground="#CCFFFFFF"/>
                        <TextBlock Text="۰" FontSize="28" FontWeight="Bold"
                                   Foreground="White" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Pending Cheques - Red -->
                <Border Background="#FFD13438" CornerRadius="10" Padding="18,16" Margin="6">
                    <StackPanel>
                        <TextBlock Text="&#xE7F3;  چک‌های در انتظار" FontFamily="Segoe MDL2 Assets"
                                   FontSize="12" Foreground="#CCFFFFFF"/>
                        <TextBlock Text="۰" FontSize="28" FontWeight="Bold"
                                   Foreground="White" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Low Stock - Teal -->
                <Border Background="#FF0D9488" CornerRadius="10" Padding="18,16" Margin="6">
                    <StackPanel>
                        <TextBlock Text="&#xE7BA;  هشدار موجودی" FontFamily="Segoe MDL2 Assets"
                                   FontSize="12" Foreground="#CCFFFFFF"/>
                        <TextBlock Text="۰ کالا" FontSize="28" FontWeight="Bold"
                                   Foreground="White" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Quick Actions -->
            <TextBlock Text="دسترسی سریع" FontSize="17" FontWeight="Bold" Margin="8,8,8,12"/>
            <UniformGrid Columns="4">
                <Button Content="&#xE74C;  صندوق فروش (F1)"
                        Style="{StaticResource PrimaryButton}" Margin="6"/>
                <Button Content="&#xE71C;  کالای جدید"
                        Style="{StaticResource SuccessButton}" Margin="6"/>
                <Button Content="&#xE77B;  مشتری جدید"
                        Style="{StaticResource WarningButton}" Margin="6"/>
                <Button Content="&#xE7F3;  ثبت چک"
                        Style="{StaticResource DangerButton}" Margin="6"/>
            </UniformGrid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
