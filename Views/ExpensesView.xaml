<UserControl x:Class="PosAccountingApp.Views.ExpensesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosAccountingApp.Converters"
             xmlns:ctrl="clr-namespace:PosAccountingApp.Controls">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:EnumToPersianConverter x:Key="EnumToPersian"/>
    </UserControl.Resources>

    <DockPanel Margin="14">
        <Border DockPanel.Dock="Top" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,0" VerticalContentAlignment="Center"/>
                <Button Grid.Column="1" Content="  هزینه جدید"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ToggleAddPanelCommand}"/>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}"
                Visibility="{Binding IsAddPanelOpen, Converter={StaticResource BoolToVis}}"
                Margin="0,0,0,10" Padding="18">
            <StackPanel>
                <TextBlock Text="ثبت هزینه جدید" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"
                           Foreground="{StaticResource AccentBrush}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="4">
                        <TextBlock Text="دسته‌بندی" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding EditCategory}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="4">
                        <TextBlock Text="مبلغ" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditAmount, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="4">
                        <TextBlock Text="تاریخ" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                        <DatePicker SelectedDate="{Binding EditDate}"/>
                    </StackPanel>
                </Grid>
                <StackPanel Margin="4,8,4,0">
                    <TextBlock Text="توضیحات" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="50"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
                    <Button Content="ذخیره" Style="{StaticResource PrimaryButton}" Margin="0,0,6,0"
                            Command="{Binding SaveExpenseCommand}"/>
                    <Button Content="انصراف" Style="{StaticResource DangerButton}"
                            Command="{Binding CancelEditCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ctrl:PaginatedDataGrid x:Name="PagedGrid"/>
    </DockPanel>
</UserControl>
