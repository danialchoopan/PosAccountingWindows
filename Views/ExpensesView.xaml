<UserControl x:Class="PosAccountingApp.Views.ExpensesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosAccountingApp.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:EnumToPersianConverter x:Key="EnumToPersian"/>
    </UserControl.Resources>

    <DockPanel Margin="14">
        <Border DockPanel.Dock="Top" Margin="0,0,0,10">
            <Button Content="  هزینه جدید"
                    Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"
                    Command="{Binding ToggleAddPanelCommand}"/>
        </Border>

        <!-- Add Panel -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}"
                Visibility="{Binding IsAddPanelOpen, Converter={StaticResource BoolToVis}}"
                Margin="0,0,0,10" Padding="16">
            <StackPanel>
                <TextBlock Text="ثبت هزینه جدید" FontSize="15" FontWeight="Bold" Margin="0,0,0,10"
                           Foreground="#FF0078D4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="4">
                        <TextBlock Text="دسته‌بندی" FontSize="11" Foreground="#FF888888" Margin="0,0,0,3"/>
                        <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding EditCategory}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="4">
                        <TextBlock Text="مبلغ" FontSize="11" Foreground="#FF888888" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding EditAmount, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="4">
                        <TextBlock Text="تاریخ" FontSize="11" Foreground="#FF888888" Margin="0,0,0,3"/>
                        <DatePicker SelectedDate="{Binding EditDate}"/>
                    </StackPanel>
                </Grid>
                <StackPanel Margin="4,8,4,0">
                    <TextBlock Text="توضیحات" FontSize="11" Foreground="#FF888888" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" Height="50"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
                    <Button Content="ذخیره" Style="{StaticResource PrimaryButton}" Margin="0,0,6,0"
                            Command="{Binding SaveExpenseCommand}"/>
                    <Button Content="انصراف" Style="{StaticResource DangerButton}"
                            Command="{Binding CancelEditCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Data Grid or Empty State -->
        <Grid>
            <DataGrid ItemsSource="{Binding Expenses}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="دسته" Binding="{Binding Category}" Width="120"/>
                    <DataGridTextColumn Header="توضیحات" Binding="{Binding Description}" Width="*"/>
                    <DataGridTextColumn Header="مبلغ" Binding="{Binding Amount}" Width="120"/>
                    <DataGridTextColumn Header="تاریخ" Binding="{Binding Date, StringFormat=yyyy/MM/dd}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
            <TextBlock Text="هنوز هزینه‌ای ثبت نشده است. روی دکمه هزینه جدید کلیک کنید."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="14" Foreground="#FFAAAAAA" Visibility="Collapsed">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Expenses.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </DockPanel>
</UserControl>
