<Window x:Class="PosAccountingApp.Views.AddPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="افزودن"
        Width="600" Height="500"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        Background="{StaticResource BgBrush}"
        Icon="{StaticResource AppIcon}">

    <DockPanel Margin="20">
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{StaticResource AccentBrush}"
                CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
            <Grid>
                <TextBlock x:Name="TitleText" Text="افزودن"
                           FontSize="18" FontWeight="Bold" Foreground="White"
                           VerticalAlignment="Center"/>
                <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                        Background="Transparent" BorderThickness="0"
                        Foreground="White" FontSize="16" Cursor="Hand"
                        HorizontalAlignment="Left" Click="Close_Click"/>
            </Grid>
        </Border>

        <!-- Content area -->
        <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" MaxHeight="320">
            <StackPanel x:Name="ContentPanel"/>
        </ScrollViewer>

        <!-- Attachment -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}"
                Margin="0,0,0,12" Padding="14">
            <StackPanel>
                <TextBlock Text="&#xE722;  پیوست تصویر" FontFamily="Segoe MDL2 Assets"
                           FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="FileNameText" Text="فایلی انتخاب نشده"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="&#xE8B7;  انتخاب فایل" FontFamily="Segoe MDL2 Assets"
                                Style="{StaticResource OutlineButton}" Margin="0,0,4,0"
                                Click="BrowseFile_Click"/>
                        <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                Style="{StaticResource DangerButton}" Padding="8,5"
                                Click="RemoveFile_Click"/>
                    </StackPanel>
                </Grid>
                <Border x:Name="ImagePreview" Background="{StaticResource HoverBgBrush}"
                        CornerRadius="6" Height="120" Margin="0,8,0,0"
                        Visibility="Collapsed">
                    <Image x:Name="PreviewImage" Stretch="Uniform"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="&#xE74E;  ذخیره" FontFamily="Segoe MDL2 Assets"
                    Style="{StaticResource PrimaryButton}" Width="160" Height="42"
                    FontSize="14" Margin="0,0,8,0" Click="Save_Click"/>
            <Button Content="&#xE7E8;  انصراف" FontFamily="Segoe MDL2 Assets"
                    Style="{StaticResource OutlineButton}" Width="120" Height="42"
                    FontSize="14" Click="Close_Click"/>
        </StackPanel>
    </DockPanel>
</Window>
