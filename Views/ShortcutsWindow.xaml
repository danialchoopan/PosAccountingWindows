<Window x:Class="PosAccountingApp.Views.ShortcutsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تنظیم میانبرهای صفحه‌کلید"
        Width="700" Height="550"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        Background="#FFF0F4F8"
        Icon="{StaticResource AppIcon}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.15*"/>
            <ColumnDefinition Width="0.70*"/>
            <ColumnDefinition Width="0.15*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="1" Background="White" CornerRadius="12"
                BorderBrush="#FFE0E0E0" BorderThickness="1"
                VerticalAlignment="Stretch" Margin="20">
            <DockPanel Margin="16">
                <TextBlock DockPanel.Dock="Top" Text="میانبرهای صفحه‌کلید" FontSize="18" FontWeight="Bold"
                           Foreground="#FF0078D4" Margin="0,0,0,12"/>

                <DataGrid x:Name="ShortcutsGrid" AutoGenerateColumns="False" IsReadOnly="False"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="کلید" Binding="{Binding Key}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="توضیح" Binding="{Binding Description}" Width="*"/>
                        <DataGridTextColumn Header="عملکرد" Binding="{Binding Action}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center"
                            Margin="0,12,0,0">
                    <Button Content="ذخیره" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                            Click="Save_Click"/>
                    <Button Content="بازگشت به پیش‌فرض" Style="{StaticResource WarningButton}"
                            Click="Reset_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
