<UserControl x:Class="PosAccountingApp.Views.SupplierView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosAccountingApp.Converters"
             xmlns:ctrl="clr-namespace:PosAccountingApp.Controls">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Supplier List -->
        <DockPanel Grid.Column="0" Margin="0,0,10,0">
            <Border DockPanel.Dock="Top" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,8,0" VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" Content="تامین‌کننده جدید"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding ToggleAddPanelCommand}"/>
                </Grid>
            </Border>

            <!-- Total Debt Banner -->
            <Border DockPanel.Dock="Top" Background="#FFF5F7FA" BorderBrush="#FFE0E0E0"
                    BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,10">
                <Grid>
                    <TextBlock Text="کل بدهی تامین‌کنندگان:" FontSize="13" FontWeight="SemiBold"
                               HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalDebt, StringFormat=N0}" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ErrorBrush}" HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Add Panel -->
            <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}"
                    Visibility="{Binding IsAddPanelOpen, Converter={StaticResource BoolToVis}}"
                    Margin="0,0,0,10" Padding="16">
                <StackPanel>
                    <TextBlock Text="تامین‌کننده جدید" FontSize="15" FontWeight="Bold" Margin="0,0,0,10"
                               Foreground="{DynamicResource AccentBrush}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="4">
                            <TextBlock Text="نام" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                            <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="4">
                            <TextBlock Text="تلفن" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                            <TextBox Text="{Binding EditPhone, UpdateSourceTrigger=PropertyChanged}" FlowDirection="LeftToRight"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="4">
                            <TextBlock Text="آدرس" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                            <TextBox Text="{Binding EditAddress, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="4">
                            <TextBlock Text="مسئول تماس" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                            <TextBox Text="{Binding EditContactPerson, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
                        <Button Content="ذخیره" Style="{StaticResource PrimaryButton}" Margin="0,0,6,0"
                                Command="{Binding SaveSupplierCommand}"/>
                        <Button Content="انصراف" Style="{StaticResource DangerButton}"
                                Command="{Binding CancelEditCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Payment Panel -->
            <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}"
                    Visibility="{Binding IsPaymentPanelOpen, Converter={StaticResource BoolToVis}}"
                    Margin="0,0,0,10" Padding="16" BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="2">
                <StackPanel>
                    <TextBlock Text="ثبت پرداخت" FontSize="15" FontWeight="Bold" Margin="0,0,0,10"
                               Foreground="{DynamicResource SuccessBrush}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="4">
                            <TextBlock Text="مبلغ پرداخت" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                            <TextBox Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}" FlowDirection="LeftToRight"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4">
                            <TextBlock Text="توضیحات" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,3"/>
                            <TextBox Text="{Binding PaymentDescription, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
                        <Button Content="ثبت پرداخت" Style="{StaticResource SuccessButton}" Margin="0,0,6,0"
                                Command="{Binding RecordPaymentCommand}"/>
                        <Button Content="انصراف" Style="{StaticResource OutlineButton}"
                                Command="{Binding CancelPaymentCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Supplier List -->
            <Grid>
                <DataGrid ItemsSource="{Binding Suppliers}" MouseDoubleClick="SupplierGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="نام" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="تلفن" Binding="{Binding Phone}" Width="120"/>
                        <DataGridTextColumn Header="بدهی" Binding="{Binding TotalDebt}" Width="100"/>
                        <DataGridTextColumn Header="پرداختی" Binding="{Binding TotalPaid}" Width="100"/>
                        <DataGridTextColumn Header="مانده" Binding="{Binding Balance}" Width="100"/>
                        <DataGridTemplateColumn Header="عملیات" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="پرداخت" Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource SuccessBrush}" Cursor="Hand" FontSize="11"
                                                Click="PayBtn_Click" Tag="{Binding}"/>
                                        <Button Content="حذف" Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource ErrorBrush}" Cursor="Hand" FontSize="11"
                                                Click="DeleteBtn_Click" Tag="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <TextBlock Text="هنوز تامین‌کننده‌ای ثبت نشده."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Visibility="Collapsed">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Suppliers.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </DockPanel>

        <!-- Right: Ledger -->
        <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="14">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" FontSize="15" FontWeight="Bold" Margin="0,0,0,10"
                           Foreground="{DynamicResource AccentBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="دفتر تامین‌کننده"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSupplier}" Value="{x:Null}">
                                    <Setter Property="Text" Value="یک تامین‌کننده انتخاب کنید"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Grid>
                    <DataGrid ItemsSource="{Binding LedgerEntries}" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="تاریخ" Binding="{Binding EntryDate, StringFormat=yyyy/MM/dd}" Width="80"/>
                            <DataGridTextColumn Header="نوع" Binding="{Binding Type}" Width="60"/>
                            <DataGridTextColumn Header="مبلغ" Binding="{Binding Amount}" Width="100"/>
                            <DataGridTextColumn Header="توضیحات" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="شماره فاکتور" Binding="{Binding InvoiceNumber}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Text="روی تامین‌کننده کلیک کنید" HorizontalAlignment="Center"
                               VerticalAlignment="Center" Foreground="#FFAAAAAA" FontSize="13"
                               Visibility="Collapsed">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LedgerEntries.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
