<UserControl x:Class="PosAccountingApp.Controls.PaginatedDataGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PosAccountingApp.Controls">

    <DockPanel>
        <!-- Toolbar: Page size, Export, Print -->
        <Border DockPanel.Dock="Top" Padding="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Page Size -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="تعداد در صفحه:" FontSize="12" Margin="0,0,6,0"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="PageSizeCombo" Width="70" Padding="4,2"
                              SelectedIndex="1" SelectionChanged="PageSize_Changed">
                        <ComboBoxItem Content="5"/>
                        <ComboBoxItem Content="10"/>
                        <ComboBoxItem Content="20"/>
                        <ComboBoxItem Content="50"/>
                        <ComboBoxItem Content="همه"/>
                    </ComboBox>
                </StackPanel>

                <!-- Export Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="PDF  خروجی" Style="{StaticResource OutlineButton}"
                            Margin="0,0,4,0" Click="ExportPdf_Click"/>
                    <Button Content="Excel  خروجی" Style="{StaticResource OutlineButton}"
                            Margin="0,0,4,0" Click="ExportExcel_Click"/>
                    <Button Content="چاپ" Style="{StaticResource OutlineButton}"
                            Click="Print_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid x:Name="MainGrid" DockPanel.Dock="Top"
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  SelectionMode="Single" MouseDoubleClick="MainGrid_MouseDoubleClick"
                  RowHeaderWidth="0">
        </DataGrid>

        <!-- Pagination -->
        <Border DockPanel.Dock="Bottom" Padding="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="PageInfoText" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="&gt;&gt;" Style="{StaticResource OutlineButton}"
                            Padding="8,4" Margin="2,0" Click="LastPage_Click"/>
                    <Button Content="&gt;" Style="{StaticResource OutlineButton}"
                            Padding="8,4" Margin="2,0" Click="NextPage_Click"/>
                    <TextBlock x:Name="PageNumbersText" FontSize="12" Margin="8,0"
                               VerticalAlignment="Center"/>
                    <Button Content="&lt;" Style="{StaticResource OutlineButton}"
                            Padding="8,4" Margin="2,0" Click="PrevPage_Click"/>
                    <Button Content="&lt;&lt;" Style="{StaticResource OutlineButton}"
                            Padding="8,4" Margin="2,0" Click="FirstPage_Click"/>
                </StackPanel>

                <TextBlock Grid.Column="2" x:Name="TotalText" FontSize="12"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </DockPanel>
</UserControl>
