<UserControl x:Class="PosAccountingApp.Controls.PaginatedDataGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="تعداد:" FontSize="12" Margin="0,0,6,0"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="PageSizeCombo" Width="70" Padding="4,2"
                              SelectedIndex="1" SelectionChanged="PageSize_Changed">
                        <ComboBoxItem Content="5"/>
                        <ComboBoxItem Content="10"/>
                        <ComboBoxItem Content="20"/>
                        <ComboBoxItem Content="50"/>
                        <ComboBoxItem Content="همه"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="PDF" Style="{StaticResource PrimaryButton}"
                            Padding="10,5" Margin="0,0,4,0" FontSize="11" Click="ExportPdf_Click"/>
                    <Button Content="Excel" Style="{StaticResource SuccessButton}"
                            Padding="10,5" Margin="0,0,4,0" FontSize="11" Click="ExportExcel_Click"/>
                    <Button Content="چاپ" Style="{StaticResource OutlineButton}"
                            Padding="10,5" FontSize="11" Click="Print_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid x:Name="MainGrid" DockPanel.Dock="Top"/>

        <!-- Pagination -->
        <Border DockPanel.Dock="Bottom" Padding="0,6,0,0"
                x:Name="PaginationBar" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="PageInfoText" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="&gt;&gt;" Style="{StaticResource OutlineButton}"
                            Padding="6,3" Margin="2,0" Click="LastPage_Click"/>
                    <Button Content="&gt;" Style="{StaticResource OutlineButton}"
                            Padding="6,3" Margin="2,0" Click="NextPage_Click"/>
                    <TextBlock x:Name="PageNumbersText" FontSize="12" Margin="6,0"
                               VerticalAlignment="Center"/>
                    <Button Content="&lt;" Style="{StaticResource OutlineButton}"
                            Padding="6,3" Margin="2,0" Click="PrevPage_Click"/>
                    <Button Content="&lt;&lt;" Style="{StaticResource OutlineButton}"
                            Padding="6,3" Margin="2,0" Click="FirstPage_Click"/>
                </StackPanel>
                <TextBlock Grid.Column="2" x:Name="TotalText" FontSize="12"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Empty State -->
        <Border x:Name="EmptyState" Visibility="Collapsed"
                Background="Transparent" Padding="0,60,0,60">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                           Foreground="#FFCCCCCC" HorizontalAlignment="Center"/>
                <TextBlock x:Name="EmptyText" Text="داده‌ای موجود نیست"
                           FontSize="16" Foreground="#FFAAAAAA"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </DockPanel>
</UserControl>
