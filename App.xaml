<Application x:Class="PosAccountingApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosAccountingApp.Converters"
             Startup="OnStartup"
             Exit="OnExit"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Themes.xaml"/>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Default brush values (set before ThemeManager applies theme) -->
            <SolidColorBrush x:Key="BgBrush" Color="#FFF5F7FA"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="White"/>
            <SolidColorBrush x:Key="SidebarBgBrush" Color="#FFE8EEF4"/>
            <SolidColorBrush x:Key="CardBgBrush" Color="White"/>
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF1A2332"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF6B7B8D"/>
            <SolidColorBrush x:Key="AccentBrush" Color="#FF1565C0"/>
            <SolidColorBrush x:Key="AccentDarkBrush" Color="#FF0D47A1"/>
            <SolidColorBrush x:Key="ErrorBrush" Color="#FFD32F2F"/>
            <SolidColorBrush x:Key="SuccessBrush" Color="#FF2E7D32"/>
            <SolidColorBrush x:Key="WarningBrush" Color="#FFF57F17"/>
            <SolidColorBrush x:Key="BorderBrush" Color="#FFD6DEE8"/>
            <SolidColorBrush x:Key="InputBgBrush" Color="White"/>
            <SolidColorBrush x:Key="InputBorderBrush" Color="#FFB0BEC5"/>
            <SolidColorBrush x:Key="HoverBgBrush" Color="#FFF0F4F8"/>
            <SolidColorBrush x:Key="RowAltBgBrush" Color="#FFFAFBFC"/>
            <SolidColorBrush x:Key="HeaderBgBrush" Color="#FFEDF2F7"/>
            <SolidColorBrush x:Key="BadgeBgBrush" Color="#FFE3F2FD"/>
            <SolidColorBrush x:Key="BadgeFgBrush" Color="#FF1565C0"/>

            <!-- Global Converters -->
            <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <conv:EnumToPersianConverter x:Key="EnumToPersian"/>
            <conv:DecimalToPersianStringConverter x:Key="DecToPersian"/>
            <conv:JalaliDateConverter x:Key="JalaliDate"/>

            <!-- App Icon -->
            <DrawingImage x:Key="AppIcon">
                <DrawingImage.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="#FF0078D4">
                            <GeometryDrawing.Geometry>
                                <EllipseGeometry Center="16,16" RadiusX="14" RadiusY="14"/>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                        <GeometryDrawing Brush="White">
                            <GeometryDrawing.Geometry>
                                <PathGeometry Figures="M10,10 L22,10 M10,16 L20,16 M10,22 L18,22"/>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingGroup>
                </DrawingImage.Drawing>
            </DrawingImage>
        </ResourceDictionary>
    </Application.Resources>
</Application>
