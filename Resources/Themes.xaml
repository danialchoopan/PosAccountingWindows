<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- LIGHT THEME (default) -->
    <ResourceDictionary x:Key="LightTheme">
        <Color x:Key="BgColor">#FFF8F8F8</Color>
        <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
        <Color x:Key="SidebarBg">#FFF5F5F5</Color>
        <Color x:Key="CardBg">#FFFFFFFF</Color>
        <Color x:Key="TextPrimaryColor">#FF222222</Color>
        <Color x:Key="TextSecondaryColor">#FF888888</Color>
        <Color x:Key="AccentColor">#FF0078D4</Color>
        <Color x:Key="AccentDarkColor">#FF005A9E</Color>
        <Color x:Key="ErrorColor">#FFD13438</Color>
        <Color x:Key="SuccessColor">#FF107C10</Color>
        <Color x:Key="WarningColor">#FFFF8C00</Color>
        <Color x:Key="BorderColor">#FFE0E0E0</Color>
        <Color x:Key="InputBg">#FFFFFFFF</Color>
        <Color x:Key="InputBorder">#FFCCCCCC</Color>
        <Color x:Key="HoverBg">#FFF3F3F3</Color>
        <Color x:Key="RowAltBg">#FFFAFAFA</Color>
        <Color x:Key="HeaderBg">#FFF0F0F0</Color>
        <Color x:Key="BadgeBg">#FFE8F4FD</Color>
        <Color x:Key="BadgeFg">#FF0078D4</Color>
    </ResourceDictionary>

    <!-- DARK THEME -->
    <ResourceDictionary x:Key="DarkTheme">
        <Color x:Key="BgColor">#FF1A1A2E</Color>
        <Color x:Key="SurfaceColor">#FF222240</Color>
        <Color x:Key="SidebarBg">#FF141428</Color>
        <Color x:Key="CardBg">#FF2A2A48</Color>
        <Color x:Key="TextPrimaryColor">#FFEEEEEE</Color>
        <Color x:Key="TextSecondaryColor">#FF999999</Color>
        <Color x:Key="AccentColor">#FF4DA3FF</Color>
        <Color x:Key="AccentDarkColor">#FF2B8AD9</Color>
        <Color x:Key="ErrorColor">#FFFF6B6B</Color>
        <Color x:Key="SuccessColor">#FF6BCB77</Color>
        <Color x:Key="WarningColor">#FFFFB84D</Color>
        <Color x:Key="BorderColor">#FF3A3A5C</Color>
        <Color x:Key="InputBg">#FF2E2E50</Color>
        <Color x:Key="InputBorder">#FF4A4A6A</Color>
        <Color x:Key="HoverBg">#FF333358</Color>
        <Color x:Key="RowAltBg">#FF252545</Color>
        <Color x:Key="HeaderBg">#FF202040</Color>
        <Color x:Key="BadgeBg">#FF1A3A5C</Color>
        <Color x:Key="BadgeFg">#FF4DA3FF</Color>
    </ResourceDictionary>

</ResourceDictionary>
